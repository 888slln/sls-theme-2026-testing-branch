    {%- if request.page_type == 'product' and product -%}
      <script>
document.addEventListener("DOMContentLoaded", function () {
  const REZ_SELECTOR = ".rez-button-wrapper";
  const REZ_BUTTON_SELECTOR = ".rez-stock-notification-button";
  const REZ_BUTTON_TEXT = "Notify Me When It’s Back";
  const BUTTONS_SELECTOR = ".product-form__buttons";
  const variantAvailability = {
    {%- for variant in product.variants -%}
      "{{ variant.id }}": {{ variant.available | json }}{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  };

  let bodyObserver = null;
  let formObserver = null;
  let syncTimer = null;

  function getRezWrap() {
    return document.querySelector(REZ_SELECTOR);
  }

  function getBuyButtons() {
    return document.querySelector(BUTTONS_SELECTOR);
  }

  function getBuyRow(buyButtons) {
    if (!buyButtons) return null;
    return buyButtons.querySelector(".fl.gap.mb15") || buyButtons.querySelector(".fl.gap");
  }

  function getSelectedVariantId() {
    const formInput = document.querySelector('form[action*="/cart/add"] input[name="id"], form[action*="/cart/add"] select[name="id"]');
    if (formInput && formInput.value) return String(formInput.value);

    const variantInput = document.querySelector(".product-variant-id");
    return variantInput && variantInput.value ? String(variantInput.value) : "";
  }

  function syncRezInputs(rezWrap, variantId) {
    if (!rezWrap || !variantId) return;

    rezWrap.setAttribute("data-sls-variant-id", variantId);

    const rezScopes = [rezWrap].concat(Array.from(document.querySelectorAll(".rez-notify-modal-content")));

    rezScopes.forEach(function (scope) {
      const variantFields = scope.querySelectorAll(
        'input[name="id"], input[name="variant"], input[name="variant_id"], input[name="variantId"], select[name="id"], select[name="variant"], select[name="variant_id"], select[name="variantId"], .rez-notify-variant-select'
      );

      variantFields.forEach(function (field) {
        if (!("value" in field)) return;

        if (field.tagName === "SELECT") {
          const matchingOption = Array.from(field.options || []).find(function (option) {
            return String(option.value) === variantId;
          });
          if (!matchingOption) return;
        }

        if (String(field.value) !== variantId) {
          field.value = variantId;
          field.dispatchEvent(new Event("change", { bubbles: true }));
        }
      });
    });
  }

  function syncRezButtonText(root) {
    const scope = root && root.querySelectorAll ? root : document;
    const buttons = Array.from(scope.querySelectorAll(REZ_BUTTON_SELECTOR));

    if (scope.matches && scope.matches(REZ_BUTTON_SELECTOR)) {
      buttons.unshift(scope);
    }

    buttons.forEach(function (button) {
      if (button.textContent.trim() !== REZ_BUTTON_TEXT) {
        button.textContent = REZ_BUTTON_TEXT;
      }

      button.setAttribute("aria-label", REZ_BUTTON_TEXT);
    });
  }

  function setRezVisibility(rezWrap, isSoldOut) {
    rezWrap.hidden = !isSoldOut;
    rezWrap.classList.toggle("sls-rez-visible", isSoldOut);
    rezWrap.classList.toggle("sls-rez-hidden", !isSoldOut);
    syncRezButtonText(rezWrap);

    if (isSoldOut) {
      rezWrap.style.removeProperty("display");
    } else {
      rezWrap.style.display = "none";
    }
  }

  function syncRezState(variant) {
    const rezWrap = getRezWrap();
    if (!rezWrap) return false;

    if (variant === false) {
      setRezVisibility(rezWrap, false);
      return true;
    }

    const variantId = variant && variant.id ? String(variant.id) : getSelectedVariantId();
    const isSoldOut = variantId && (variant && typeof variant.available === "boolean" ? !variant.available : variantAvailability[variantId] === false);

    syncRezInputs(rezWrap, variantId);
    syncRezButtonText(rezWrap);
    setRezVisibility(rezWrap, Boolean(isSoldOut));

    const buyButtons = getBuyButtons();
    const buyRow = getBuyRow(buyButtons);
    if (buyRow && buyRow.nextElementSibling !== rezWrap) {
      buyRow.insertAdjacentElement("afterend", rezWrap);
    }

    return true;
  }

  function scheduleSync(variant, delay) {
    clearTimeout(syncTimer);
    syncTimer = setTimeout(function () {
      syncRezState(variant);
    }, typeof delay === "number" ? delay : 50);
  }

  window.SLSRezNotifySync = function (variant) {
    scheduleSync(variant, 0);
    setTimeout(function () { syncRezState(variant); }, 120);
    setTimeout(function () { syncRezState(variant); }, 350);
  };

  function watchProductForm() {
    const buyButtons = getBuyButtons();
    if (!buyButtons || formObserver) return;

    formObserver = new MutationObserver(function () {
      scheduleSync(null, 30);
    });

    formObserver.observe(buyButtons, {
      childList: true,
      subtree: true
    });
  }

  function watchForLateRez() {
    syncRezState(null);
    watchProductForm();

    bodyObserver = new MutationObserver(function (mutations) {
      const relevant = mutations.some(function (mutation) {
        if (!mutation.target || mutation.target.nodeType !== 1) return false;

        if (
          mutation.target.matches &&
          mutation.target.matches(REZ_SELECTOR + ", " + BUTTONS_SELECTOR)
        ) {
          return true;
        }

        if (
          mutation.target.closest &&
          mutation.target.closest(REZ_SELECTOR + ", " + BUTTONS_SELECTOR)
        ) {
          return true;
        }

        return mutation.addedNodes && mutation.addedNodes.length > 0;
      });

      if (relevant) {
        scheduleSync(null, 30);
        watchProductForm();
      }
    });

    bodyObserver.observe(document.body, {
      childList: true,
      subtree: true
    });
  }

  document.addEventListener("change", function (event) {
    if (event.target && event.target.closest && event.target.closest("variant-selects, variant-radios, product-form")) {
      scheduleSync(null, 60);
    }
  });

  watchForLateRez();
});
</script>
