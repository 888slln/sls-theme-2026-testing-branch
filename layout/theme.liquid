<script>
document.addEventListener('DOMContentLoaded', function () {
  if (window.__lumeSmileVisibilityGuardActive) return;
  window.__lumeSmileVisibilityGuardActive = true;

  const stickyCart = document.querySelector('.stickyCart');
  const drawerWrap = document.querySelector('.ctdrawer');
  const drawerEl = document.querySelector('cart-drawer, #CartDrawer');

  let smileTargets = [];
  let scheduled = false;
  let rescanTimer = null;

  function isCartOpen() {
    return !!(
      (drawerWrap && drawerWrap.classList.contains('active')) ||
      (drawerEl && (
        drawerEl.classList.contains('active') ||
        drawerEl.hasAttribute('open') ||
        drawerEl.getAttribute('aria-hidden') === 'false'
      ))
    );
  }

  function isBlockingOverlayOpen() {
    return document.documentElement.classList.contains('actMbNav') ||
      document.documentElement.classList.contains('actHmbNav') ||
      document.documentElement.classList.contains('searchact');
  }

  function getStickyOffset() {
    if (!stickyCart) return 0;

    const style = window.getComputedStyle(stickyCart);
    const rect = stickyCart.getBoundingClientRect();

    const visible =
      style.display !== 'none' &&
      style.visibility !== 'hidden' &&
      parseFloat(style.opacity || '1') > 0 &&
      rect.height > 0 &&
      rect.bottom > 0 &&
      rect.top < window.innerHeight;

    return visible ? Math.ceil(rect.height) : 0;
  }

  function isLauncherButton(el) {
    if (!el || el.nodeType !== 1) return false;

    const aria = (el.getAttribute('aria-label') || '').toLowerCase();
    const title = (el.getAttribute('title') || '').toLowerCase();
    const id = (el.id || '').toLowerCase();
    const cls = String(el.className || '').toLowerCase();

    return (
      aria.includes('open smile.io rewards program') ||
      title.includes('smile') ||
      id.includes('smile-launcher') ||
      cls.includes('smile-launcher')
    );
  }

  function isLauncherIframe(el) {
    if (!el || el.nodeType !== 1 || el.tagName !== 'IFRAME') return false;

    const src = (el.getAttribute('src') || '').toLowerCase();
    const title = (el.getAttribute('title') || '').toLowerCase();

    return src.includes('smile') || title.includes('smile');
  }

  function isFixedElement(el) {
    try {
      return window.getComputedStyle(el).position === 'fixed';
    } catch (e) {
      return false;
    }
  }

  function collectSmileTargets() {
    const found = new Set();

    document.querySelectorAll('button, iframe').forEach(function (el) {
      const isTarget =
        (el.tagName === 'BUTTON' && isLauncherButton(el)) ||
        (el.tagName === 'IFRAME' && isLauncherIframe(el));

      if (!isTarget) return;
      if (!isFixedElement(el)) return;

      found.add(el);
    });

    smileTargets = Array.from(found);
  }

  function applyState() {
    scheduled = false;

    if (!smileTargets.length) return;

    const cartOpen = isCartOpen() || isBlockingOverlayOpen();

    smileTargets.forEach(function (el) {
      el.style.transition = 'opacity 0.08s ease, visibility 0.08s ease';

      if (cartOpen) {
        el.style.opacity = '0';
        el.style.visibility = 'hidden';
        el.style.pointerEvents = 'none';
      } else {
        el.style.opacity = '';
        el.style.visibility = '';
        el.style.pointerEvents = '';
        el.style.transform = '';
      }
    });
  }

  function queueApply() {
    if (scheduled) return;
    scheduled = true;
    requestAnimationFrame(applyState);
  }

  function rescanAndApply(delay) {
    clearTimeout(rescanTimer);
    rescanTimer = setTimeout(function () {
      collectSmileTargets();
      applyState();
    }, typeof delay === 'number' ? delay : 120);
  }

  collectSmileTargets();
  applyState();

  if (stickyCart) {
    new MutationObserver(function () {
      queueApply();
      setTimeout(queueApply, 120);
    }).observe(stickyCart, {
      attributes: true,
      childList: true,
      subtree: true
    });
  }

  if (drawerWrap) {
    new MutationObserver(queueApply).observe(drawerWrap, {
      attributes: true,
      attributeFilter: ['class', 'open', 'aria-hidden']
    });
  }

  if (drawerEl) {
    new MutationObserver(queueApply).observe(drawerEl, {
      attributes: true,
      attributeFilter: ['class', 'open', 'aria-hidden']
    });
  }

  const pageObserver = new MutationObserver(function (mutations) {
    const relevant = mutations.some(function (mutation) {
      if (!mutation.addedNodes || !mutation.addedNodes.length) return false;

      return Array.from(mutation.addedNodes).some(function (node) {
        if (!node || node.nodeType !== 1) return false;

        if (
          (node.tagName === 'BUTTON' && isLauncherButton(node)) ||
          (node.tagName === 'IFRAME' && isLauncherIframe(node))
        ) {
          return true;
        }

        if (node.querySelector) {
          return !!node.querySelector('button[aria-label="Open Smile.io Rewards Program"], iframe[src*="smile"], iframe[src*="Smile"], iframe[title*="smile"], iframe[title*="Smile"]');
        }

        return false;
      });
    });

    if (relevant) {
      rescanAndApply(120);
    }
  });

  pageObserver.observe(document.body, {
    childList: true,
    subtree: true
  });

  window.addEventListener('resize', function () {
    queueApply();
    setTimeout(queueApply, 120);
  }, { passive: true });

  window.addEventListener('scroll', queueApply, { passive: true });

  rescanAndApply(800);
});
</script>


<script>
(function () {
  const SMILE_Z_INDEX = '650';
  const SMILE_SELECTORS = [
    'button[aria-label*="Smile"]',
    'button[aria-label*="smile"]',
    'button[title*="Smile"]',
    'button[title*="smile"]',
    'iframe[src*="smile"]',
    'iframe[src*="Smile"]',
    'iframe[title*="Smile"]',
    'iframe[title*="smile"]',
    '[id*="smile"]',
    '[id*="Smile"]',
    '[class*="smile"]',
    '[class*="Smile"]',
    '[id*="sweettooth"]',
    '[class*="sweettooth"]'
  ].join(',');

  let applyTimer = null;

  function getElementSignature(el) {
    return [
      el.id || '',
      String(el.className || ''),
      el.getAttribute('aria-label') || '',
      el.getAttribute('title') || '',
      el.getAttribute('src') || ''
    ].join(' ').toLowerCase();
  }

  function isSmileElement(el) {
    if (!el || el.nodeType !== 1) return false;
    const signature = getElementSignature(el);
    return (
      signature.includes('smile') ||
      signature.includes('sweettooth') ||
      signature.includes('open smile.io rewards program')
    );
  }

  function isFixedLayer(el) {
    try {
      const position = window.getComputedStyle(el).position;
      return position === 'fixed' || position === 'sticky';
    } catch (e) {
      return false;
    }
  }

  function isVisibleLayer(el) {
    try {
      const style = window.getComputedStyle(el);
      const rect = el.getBoundingClientRect();

      return (
        style.display !== 'none' &&
        style.visibility !== 'hidden' &&
        style.pointerEvents !== 'none' &&
        parseFloat(style.opacity || '1') > 0 &&
        rect.width > 0 &&
        rect.height > 0 &&
        rect.bottom > 0 &&
        rect.right > 0 &&
        rect.top < window.innerHeight &&
        rect.left < window.innerWidth
      );
    } catch (e) {
      return false;
    }
  }

  function isOpenPanel(el) {
    if (!isVisibleLayer(el)) return false;
    const rect = el.getBoundingClientRect();
    return rect.width >= 180 && rect.height >= 160;
  }

  function isBlockingOverlayOpen() {
    return document.documentElement.classList.contains('actMbNav') ||
      document.documentElement.classList.contains('actHmbNav') ||
      document.documentElement.classList.contains('searchact');
  }

  function applySmileStacking() {
    const targets = Array.from(document.querySelectorAll(SMILE_SELECTORS)).filter(function (el) {
      return isSmileElement(el) && isFixedLayer(el);
    });

    let panelOpen = false;
    const blocked = isBlockingOverlayOpen();

    targets.forEach(function (el) {
      el.style.setProperty('z-index', SMILE_Z_INDEX, 'important');
      if (blocked) {
        el.dataset.lumeSmileHidden = 'true';
        el.style.setProperty('opacity', '0', 'important');
        el.style.setProperty('visibility', 'hidden', 'important');
        el.style.setProperty('pointer-events', 'none', 'important');
      } else if (el.dataset.lumeSmileHidden === 'true') {
        delete el.dataset.lumeSmileHidden;
        el.style.removeProperty('opacity');
        el.style.removeProperty('visibility');
        el.style.removeProperty('pointer-events');
      }
      if (isOpenPanel(el)) panelOpen = true;
    });

    document.documentElement.classList.toggle('lume-smile-open', panelOpen);
  }

  function queueApply(delay) {
    clearTimeout(applyTimer);
    applyTimer = setTimeout(applySmileStacking, typeof delay === 'number' ? delay : 40);
  }

  function initSmileStackingGuard() {
    applySmileStacking();
    queueApply(400);

    document.addEventListener('click', function () {
      applySmileStacking();
      queueApply(320);
    }, true);

    window.addEventListener('resize', function () {
      queueApply(40);
    }, { passive: true });

    new MutationObserver(function (mutations) {
      const relevant = mutations.some(function (mutation) {
        if (mutation.type === 'attributes') {
          return isSmileElement(mutation.target);
        }

        return Array.from(mutation.addedNodes || []).some(function (node) {
          if (!node || node.nodeType !== 1) return false;
          return isSmileElement(node) || !!(node.querySelector && node.querySelector(SMILE_SELECTORS));
        });
      });

      if (relevant) queueApply(40);
    }).observe(document.body, {
      childList: true,
      subtree: true,
      attributes: true,
      attributeFilter: ['class', 'style', 'aria-hidden', 'hidden']
    });

    new MutationObserver(function () {
      queueApply(20);
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class']
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSmileStackingGuard);
  } else {
    initSmileStackingGuard();
  }
})();
</script>



































<script>
(function () {
  function styleHitsy(container) {
    if (!container || !container.shadowRoot) return;
    const root = container.shadowRoot;

    if (root.getElementById('studio-lume-hitsy-style')) return;

    const style = document.createElement('style');
    style.id = 'studio-lume-hitsy-style';
    style.textContent = `
      :host {
        display: block !important;
      }

      div[style*="max-width: 100%"] {
        margin: 0 12px 14px 0 !important;
        max-width: calc(100% - 12px) !important;
        display: block !important;
      }

      .hitsy-card {
        background: #f5f5f5 !important;
        border: 1px solid #eee9e4 !important;
        border-radius: 14px !important;
        padding: 12px 16px !important;
        display: flex !important;
        flex-direction: column !important;
        gap: 8px !important;
        box-shadow: none !important;
      }

      hitsy-text[configindex="0"] > div,
      hitsy-text[texttype="before"] > div,
      hitsy-text[texttype="after"] > div {
        width: 100% !important;
        text-align: center !important;
        line-height: 1.35 !important;
        font-size: 12px !important;
        font-weight: 400 !important;
        color: #222222 !important;
        letter-spacing: 0 !important;
        margin: 0 !important;
      }

      hitsy-text[texttype="after"] > div {
        font-size: 12px !important;
        font-weight: 600 !important;
        color: #222222 !important;
      }

      hitsy-text b {
        font-weight: 600 !important;
        color: #222222 !important;
      }

      hitsy-progress {
        display: block !important;
        margin: 0 !important;
      }

      .hitsy-progress-background {
        width: 100% !important;
        position: relative !important;
        display: flex !important;
        height: 22px !important;
        justify-content: center !important;
        align-items: center !important;
      }

      .hitsy-progress-background > div {
        display: flex !important;
        width: 100% !important;
        height: 6px !important;
        background: #cbc4bc !important;
        border-radius: 999px !important;
        overflow: visible !important;
        position: relative !important;
      }

      .hitsy-progress-background > div > div {
        height: 100% !important;
        background: #aca39a !important;
        border-radius: 999px !important;
        transition: width 0.35s ease !important;
      }

      .hitsy-progress-icon {
        position: absolute !important;
        top: 50% !important;
        transform: translate(-50%, -50%) !important;
        height: 22px !important;
        width: 22px !important;
        min-width: 22px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        border-radius: 50% !important;
        box-sizing: border-box !important;
        background: #ffffff !important;
        border: 1px solid #cbc4bc !important;
        box-shadow: 0 0 0 2px #f5f5f5 !important;
        padding: 0 !important;
      }

      .hitsy-progress-icon svg {
        width: 11px !important;
        height: 11px !important;
        display: block !important;
        fill: #867e73 !important;
        margin: 0 !important;
      }

      /* unlocked state */
      .studio-lume-hitsy-unlocked .hitsy-card {
        padding: 14px 16px !important;
        gap: 0 !important;
      }

      .studio-lume-hitsy-unlocked hitsy-progress {
        display: none !important;
      }

      .studio-lume-hitsy-unlocked hitsy-text[texttype="before"] > div {
        font-size: 15px !important;
        line-height: 1.35 !important;
        font-weight: 600 !important;
        color: #222222 !important;
        text-align: center !important;
      }

      .studio-lume-hitsy-unlocked hitsy-text[texttype="after"] {
        display: none !important;
      }
    `;
    root.appendChild(style);

    function isUnlockedText(text) {
      if (!text) return false;
      const t = text.replace(/\s+/g, ' ').trim().toLowerCase();
      return t.includes('free express shipping') &&
             (t.includes('unlocked') || t.includes('eligible') || t.includes('you\'ve unlocked'));
    }

    function applyInlineFixes() {
      const hostWrap = root.querySelector('div[style*="max-width: 100%"]');
      if (hostWrap) {
        hostWrap.style.margin = '0 12px 14px 0';
        hostWrap.style.maxWidth = 'calc(100% - 12px)';
        hostWrap.style.display = 'block';
      }

      const card = root.querySelector('.hitsy-card');
      if (card) {
        card.style.backgroundColor = '#f5f5f5';
        card.style.border = '1px solid #eee9e4';
        card.style.borderRadius = '14px';
        card.style.padding = '12px 16px';
        card.style.gap = '8px';
      }

      root.querySelectorAll('hitsy-text > div').forEach(function (el) {
        el.style.textAlign = 'center';
        el.style.lineHeight = '1.35';
        el.style.fontSize = '12px';
        el.style.color = '#222222';
        el.style.margin = '0';
      });

      const beforeText = root.querySelector('hitsy-text[texttype="before"] > div');
      if (beforeText) beforeText.style.fontWeight = '400';

      const afterText = root.querySelector('hitsy-text[texttype="after"] > div');
      if (afterText) {
        afterText.style.fontWeight = '600';
        afterText.style.color = '#222222';
      }

      root.querySelectorAll('hitsy-text b').forEach(function (el) {
        el.style.fontWeight = '600';
        el.style.color = '#222222';
      });

      const progressBg = root.querySelector('.hitsy-progress-background');
      if (progressBg) {
        progressBg.style.height = '22px';
        progressBg.style.alignItems = 'center';
      }

      const track = root.querySelector('.hitsy-progress-background > div');
      if (track) {
        track.style.height = '6px';
        track.style.backgroundColor = '#cbc4bc';
        track.style.borderRadius = '999px';
        track.style.overflow = 'visible';
        track.style.position = 'relative';
      }

      const fill = root.querySelector('.hitsy-progress-background > div > div');
      if (fill) {
        fill.style.backgroundColor = '#aca39a';
        fill.style.borderRadius = '999px';
        fill.style.transition = 'width 0.35s ease';
      }

      root.querySelectorAll('.hitsy-progress-icon').forEach(function (icon) {
        icon.style.height = '22px';
        icon.style.width = '22px';
        icon.style.minWidth = '22px';
        icon.style.display = 'flex';
        icon.style.alignItems = 'center';
        icon.style.justifyContent = 'center';
        icon.style.borderRadius = '50%';
        icon.style.background = '#ffffff';
        icon.style.border = '1px solid #cbc4bc';
        icon.style.boxSizing = 'border-box';
        icon.style.top = '50%';
        icon.style.transform = 'translate(-50%, -50%)';
        icon.style.padding = '0';
        icon.style.boxShadow = '0 0 0 2px #f5f5f5';
      });

      root.querySelectorAll('.hitsy-progress-icon svg').forEach(function (svg) {
        svg.style.width = '11px';
        svg.style.height = '11px';
        svg.style.display = 'block';
        svg.style.fill = '#867e73';
        svg.style.margin = '0';
      });

      /* unlocked state toggle */
      const beforeTextEl = root.querySelector('hitsy-text[texttype="before"] > div');
      const hostStateTarget = hostWrap || root.host;
      const unlocked = beforeTextEl && isUnlockedText(beforeTextEl.textContent);

      if (hostStateTarget) {
        hostStateTarget.classList.toggle('studio-lume-hitsy-unlocked', !!unlocked);
      }

      if (unlocked && beforeTextEl) {
        beforeTextEl.style.fontSize = '15px';
        beforeTextEl.style.fontWeight = '600';
        beforeTextEl.style.lineHeight = '1.35';
        beforeTextEl.style.textAlign = 'center';
      }
    }

    applyInlineFixes();

    const observer = new MutationObserver(function () {
      applyInlineFixes();
    });

    observer.observe(root, {
      childList: true,
      subtree: true,
      characterData: true,
      attributes: true
    });
  }

  function initHitsyTheme() {
    document.querySelectorAll('hitsy-container').forEach(styleHitsy);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHitsyTheme);
  } else {
    initHitsyTheme();
  }

  const pageObserver = new MutationObserver(function (mutations) {
    const hasHitsyNode = mutations.some(function (mutation) {
      return Array.from(mutation.addedNodes || []).some(function (node) {
        if (!node || node.nodeType !== 1) return false;
        return node.matches && node.matches('hitsy-container') ||
          node.querySelector && node.querySelector('hitsy-container');
      });
    });

    if (hasHitsyNode) initHitsyTheme();
  });

  pageObserver.observe(document.documentElement, {
    childList: true,
    subtree: true
  });
})();
</script>















<script>
document.addEventListener('DOMContentLoaded', function () {
  if (window.__lumeSmileVisibilityGuardActive) return;
  window.__lumeSmileVisibilityGuardActive = true;

  const drawerWrap = document.querySelector('.ctdrawer');
  const drawerEl = document.querySelector('cart-drawer, #CartDrawer');

  let smileTargets = [];
  let applyQueued = false;
  let rescanTimer = null;

  function isCartOpen() {
    return !!(
      (drawerWrap && drawerWrap.classList.contains('active')) ||
      (drawerEl && (
        drawerEl.classList.contains('active') ||
        drawerEl.hasAttribute('open') ||
        drawerEl.getAttribute('aria-hidden') === 'false'
      ))
    );
  }

  function isBlockingOverlayOpen() {
    return document.documentElement.classList.contains('actMbNav') ||
      document.documentElement.classList.contains('actHmbNav') ||
      document.documentElement.classList.contains('searchact');
  }

  function isSmileLauncherButton(el) {
    if (!el || el.nodeType !== 1 || el.tagName !== 'BUTTON') return false;

    const aria = (el.getAttribute('aria-label') || '').toLowerCase();
    const title = (el.getAttribute('title') || '').toLowerCase();
    const id = (el.id || '').toLowerCase();
    const cls = String(el.className || '').toLowerCase();

    return (
      aria.includes('open smile.io rewards program') ||
      title.includes('smile') ||
      id.includes('smile-launcher') ||
      cls.includes('smile-launcher')
    );
  }

  function isSmileLauncherIframe(el) {
    if (!el || el.nodeType !== 1 || el.tagName !== 'IFRAME') return false;

    const src = (el.getAttribute('src') || '').toLowerCase();
    const title = (el.getAttribute('title') || '').toLowerCase();

    return src.includes('smile') || title.includes('smile');
  }

  function isFixedElement(el) {
    try {
      return window.getComputedStyle(el).position === 'fixed';
    } catch (e) {
      return false;
    }
  }

  function collectSmileTargets() {
    const found = new Set();

    document.querySelectorAll('button, iframe').forEach(function (el) {
      const isTarget =
        isSmileLauncherButton(el) ||
        isSmileLauncherIframe(el);

      if (!isTarget) return;
      if (!isFixedElement(el)) return;

      found.add(el);
    });

    smileTargets = Array.from(found);
  }

  function applySmileState() {
    applyQueued = false;

    if (!smileTargets.length) return;

    const cartOpen = isCartOpen() || isBlockingOverlayOpen();

    smileTargets.forEach(function (el) {
      el.style.transition = 'opacity 0.08s ease, visibility 0.08s ease';

      if (cartOpen) {
        el.style.opacity = '0';
        el.style.visibility = 'hidden';
        el.style.pointerEvents = 'none';
      } else {
        el.style.opacity = '';
        el.style.visibility = '';
        el.style.pointerEvents = '';
      }
    });
  }

  function queueApply() {
    if (applyQueued) return;
    applyQueued = true;
    requestAnimationFrame(applySmileState);
  }

  function rescanAndApply(delay) {
    clearTimeout(rescanTimer);
    rescanTimer = setTimeout(function () {
      collectSmileTargets();
      applySmileState();
    }, typeof delay === 'number' ? delay : 120);
  }

  collectSmileTargets();
  applySmileState();

  if (drawerWrap) {
    new MutationObserver(queueApply).observe(drawerWrap, {
      attributes: true,
      attributeFilter: ['class', 'open', 'aria-hidden']
    });
  }

  if (drawerEl) {
    new MutationObserver(queueApply).observe(drawerEl, {
      attributes: true,
      attributeFilter: ['class', 'open', 'aria-hidden']
    });
  }

  const pageObserver = new MutationObserver(function (mutations) {
    const relevant = mutations.some(function (mutation) {
      if (!mutation.addedNodes || !mutation.addedNodes.length) return false;

      return Array.from(mutation.addedNodes).some(function (node) {
        if (!node || node.nodeType !== 1) return false;

        if (isSmileLauncherButton(node) || isSmileLauncherIframe(node)) {
          return true;
        }

        if (node.querySelector) {
          return !!node.querySelector('button[aria-label="Open Smile.io Rewards Program"], iframe[src*="smile"], iframe[src*="Smile"], iframe[title*="smile"], iframe[title*="Smile"]');
        }

        return false;
      });
    });

    if (relevant) {
      rescanAndApply(120);
    }
  });

  pageObserver.observe(document.body, {
    childList: true,
    subtree: true
  });

  window.addEventListener('resize', queueApply, { passive: true });

  rescanAndApply(800);
});
</script>














