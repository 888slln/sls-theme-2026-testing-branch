        "customc_Nhrbtn": {
          "type": "customc",
          "name": "Tab Slider",
          "disabled": true,
          "settings": {
            "custom_liquid": "<script>\n  const SLIDER_CONFIG = {\n    // --- COLORS & STYLE ---\n    slide_bg: \"#f5f5f5\",\n    slide_text: \"#222222\",\n    border_radius: \"0px\",\n\n    // --- FONT CUSTOMISATION ---\n    h_size: \"0.875rem\",  \n    h_weight: \"700\",     \n    h_spacing: \"0px\",    \n\n    p_size: \"0.875rem\",  \n    p_weight: \"300\",     \n    p_spacing: \"0px\",    \n\n    // --- AUTOMATED TEXT ---\n    Ships_Today_Heading: \"Ships Today\",\n    Ships_Today_Sub: \"Order within the next\", \n    Ships_Tomorrow_Heading: \"Ships Tomorrow\",\n    Ships_Tomorrow_Sub: \"Order now for priority dispatch\",\n    \n    Ships_Monday_Heading: \"Ships Monday\",\n    Ships_Monday_Sub: \"Secure your spot for Monday’s first dispatch\",\n    \n    Holiday_Heading: \"Public Holiday\",\n    Holiday_Sub: \"Shipping resumes next business day\",\n\n    // --- SHIPPING LOGIC ---\n    cutoff_hour: 14, // 2:00 PM\n    cutoff_minute: 30, // 30 Minutes\n    \n    // --- QLD PUBLIC HOLIDAYS ---\n    public_holidays: [\n      '2025-01-01', '2025-01-27', '2025-04-18', '2025-04-19', '2025-04-20', '2025-04-21',\n      '2025-04-25', '2025-05-05', '2025-08-13', '2025-10-06', '2025-12-25', '2025-12-26',\n      '2026-01-01', '2026-01-26', '2026-04-03', '2026-04-04', '2026-04-05', '2026-04-06',\n      '2026-04-25', '2026-05-04', '2026-08-12', '2026-10-05', '2026-12-25', '2026-12-26', '2026-12-28'\n    ],\n\n    test_mode: {\n      enabled: false, \n      date: \"2025-12-27T10:00:00\" \n    }\n  };\n</script>\n\n<div class=\"shipping-announcer-main\" id=\"announcer-box\">\n  <div class=\"announcer-content\" id=\"style-box\">\n    <h3 id=\"dyn-h\"></h3>\n    <p id=\"dyn-p\"></p>\n  </div>\n</div>\n\n<style>\n  .shipping-announcer-main { \n    max-width: 100%; \n    margin: 10px 0; \n    overflow: hidden; \n    position: relative; \n    font-family: inherit; \n  }\n  .announcer-content { \n    padding: 25px 20px; \n    text-align: center; \n    box-sizing: border-box; \n  }\n  \n  .announcer-content h3 { \n    margin: 0 0 5px 0 !important; \n    color: inherit; \n    line-height: 1.2 !important;\n  }\n  .announcer-content p { \n    margin: 0 !important; \n    color: inherit; \n    line-height: 1.4 !important;\n  }\n</style>\n\n<script>\n  (function() {\n    const c = SLIDER_CONFIG;\n    const h = document.getElementById('dyn-h');\n    const p = document.getElementById('dyn-p');\n    const box = document.getElementById('style-box');\n    const wrapper = document.getElementById('announcer-box');\n\n    const update = () => {\n      const now = c.test_mode.enabled ? new Date(c.test_mode.date) : new Date();\n      \n      // Get Brisbane Time\n      const qParts = new Intl.DateTimeFormat('en-CA', {\n        timeZone: 'Australia/Brisbane', \n        year:'numeric', month:'2-digit', day:'2-digit', \n        hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:false\n      }).formatToParts(now);\n      \n      const q = {}; qParts.forEach(({type, value}) => q[type] = value);\n      const brisNow = new Date(now.toLocaleString(\"en-US\", {timeZone: \"Australia/Brisbane\"}));\n      \n      const dStr = `${q.year}-${q.month}-${q.day}`;\n      const hr = parseInt(q.hour);\n      const min = parseInt(q.minute);\n      const day = brisNow.getDay(); \n      \n      const isPastCutoff = (hr > c.cutoff_hour || (hr === c.cutoff_hour && min >= c.cutoff_minute));\n\n      // 1. Weekend Logic\n      if (day === 0 || day === 6 || (day === 5 && isPastCutoff)) {\n        h.innerText = c.Ships_Monday_Heading; \n        p.innerText = c.Ships_Monday_Sub;\n      } \n      // 2. Public Holiday\n      else if (c.public_holidays.includes(dStr)) {\n        h.innerText = c.Holiday_Heading; \n        p.innerText = c.Holiday_Sub;\n      } \n      // 3. After Cutoff Weekday\n      else if (isPastCutoff) {\n        h.innerText = c.Ships_Tomorrow_Heading; \n        p.innerText = c.Ships_Tomorrow_Sub;\n      } \n      // 4. Countdown\n      else {\n        h.innerText = c.Ships_Today_Heading;\n        const target = new Date(brisNow);\n        target.setHours(c.cutoff_hour, c.cutoff_minute, 0, 0);\n        const diff = target - brisNow;\n        const hh = Math.floor(diff/36e5), mm = Math.floor((diff%36e5)/6e4), ss = Math.floor((diff%6e4)/1e3);\n        p.innerHTML = `${c.Ships_Today_Sub} <strong style=\"font-weight:600\">${hh}h ${mm}m ${ss}s</strong>`;\n      }\n    };\n\n    // Apply Styles\n    h.style.fontSize = c.h_size; h.style.fontWeight = c.h_weight; h.style.letterSpacing = c.h_spacing;\n    p.style.fontSize = c.p_size; p.style.fontWeight = c.p_weight; p.style.letterSpacing = c.p_spacing;\n    \n    Object.assign(box.style, { background: c.slide_bg, color: c.slide_text });\n    wrapper.style.borderRadius = c.border_radius;\n\n    setInterval(update, 1000); \n    update();\n  })();\n</script>",
            "bm": 15
          }
        },
        "customc_fhTeiX": {
          "type": "customc",
          "name": "shipping and pickup",
          "settings": {
            "custom_liquid": "{%- assign lume_uid = section.id | default: product.id -%}\n{%- assign current_variant = product.selected_or_first_available_variant -%}\n{%- assign pick_up_availabilities = current_variant.store_availabilities | where: 'pick_up_enabled', true -%}\n\n<div class=\"lume-fulfilment\" id=\"lume-fulfilment-{{ lume_uid }}\">\n\n  <!-- DELIVERY -->\n  <div class=\"lume-row\">\n    <div class=\"lume-label\">Delivery</div>\n\n    <div class=\"lume-body\">\n      <div class=\"lume-primary\">\n        <span id=\"ship-title-{{ lume_uid }}\">Ships Today</span>\n      </div>\n\n      <div class=\"lume-secondary\">\n        <span id=\"ship-sub-{{ lume_uid }}\">Order within the next</span>\n        <span class=\"lume-timer\" id=\"ship-timer-{{ lume_uid }}\"></span>\n      </div>\n    </div>\n\n    <div class=\"lume-meta\"></div>\n  </div>\n\n  <!-- IN STORE -->\n  <div class=\"lume-row\">\n    <div class=\"lume-label\">In store</div>\n\n    <div class=\"lume-body\">\n      <pickup-availability\n        class=\"product__pickup-availabilities lume-pickup\"\n        {% if current_variant.available and pick_up_availabilities.size > 0 %}available{% endif %}\n        data-root-url=\"{{ routes.root_url }}\"\n        data-variant-id=\"{{ current_variant.id }}\"\n        data-has-only-default-variant=\"{{ product.has_only_default_variant }}\"\n      >\n        <template>\n          <pickup-availability-preview class=\"pickup-availability-preview\">\n            <span class=\"svg-wrapper\">{{- 'icon-unavailable.svg' | inline_asset_content -}}</span>\n            <div class=\"pickup-availability-info\">\n              <p class=\"caption-large\">{{ 'products.pickup_availability.unavailable' | t }}</p>\n              <button class=\"pickup-availability-button\">\n                {{ 'products.pickup_availability.refresh' | t }}\n              </button>\n            </div>\n          </pickup-availability-preview>\n        </template>\n      </pickup-availability>\n    </div>\n\n    <div class=\"lume-meta\"></div>\n  </div>\n\n</div>\n\n<script>\n(function(){\n  if (window.__lumePickupLoaded) return;\n  window.__lumePickupLoaded = true;\n  var s = document.createElement('script');\n  s.src = \"{{ 'pickup-availability.js' | asset_url }}\";\n  s.defer = true;\n  document.head.appendChild(s);\n})();\n</script>\n\n<style>\n/* ================= CONTAINER ================= */\n#lume-fulfilment-{{ lume_uid }}{\n  background:#FFFFFF;\n  border-radius:10px;\n  border:1px solid rgba(203,196,188,0.55);\n  box-shadow:\n    0 0 0 1px rgba(255,255,255,0.6) inset,\n    0 6px 20px rgba(203,196,188,0.15);\n  animation: lumeFadeUp .35s ease-out both;\n}\n\n/* ================= ROW ================= */\n#lume-fulfilment-{{ lume_uid }} .lume-row{\n  display:grid;\n  grid-template-columns: 88px 1fr auto;\n  gap:12px;\n  padding:16px 18px;\n  align-items:start;\n  position:relative;\n}\n\n/* Beige divider */\n#lume-fulfilment-{{ lume_uid }} .lume-row + .lume-row::before{\n  content:\"\";\n  position:absolute;\n  top:0;\n  left:18px;\n  right:18px;\n  height:1px;\n  background:rgba(203,196,188,0.45);\n}\n\n/* ================= TYPOGRAPHY ================= */\n#lume-fulfilment-{{ lume_uid }} .lume-label{\n  font-size:12px;\n  font-weight:500;\n  color:#867E73;\n  padding-top:2px;\n}\n\n#lume-fulfilment-{{ lume_uid }} .lume-primary{\n  font-size:13px;\n  font-weight:600;\n  color:#222222;\n  line-height:1.35;\n}\n\n#lume-fulfilment-{{ lume_uid }} .lume-secondary{\n  margin-top:6px;\n  font-size:13px;\n  font-weight:400;\n  color:#222222;\n  display:flex;\n  flex-wrap:wrap;\n  gap:8px;\n  align-items:center;\n}\n\n/* Countdown (no border, subtle highlight) */\n#lume-fulfilment-{{ lume_uid }} .lume-timer strong{\n  font-weight:600;\n  font-size:13px;\n  color:#222222;\n  background:rgba(203,196,188,0.18);\n  padding:2px 8px;\n  border-radius:6px;\n  letter-spacing:0.2px;\n  display:inline-block;\n}\n\n/* ================= PICKUP CLEANUP ================= */\n#lume-fulfilment-{{ lume_uid }} pickup-availability .svg-wrapper{ display:none !important; }\n#lume-fulfilment-{{ lume_uid }} pickup-availability .pickup-availability-preview{ padding:0 !important; }\n#lume-fulfilment-{{ lume_uid }} pickup-availability .pickup-availability-info{ margin:0 !important; }\n#lume-fulfilment-{{ lume_uid }} pickup-availability .pickup-availability-info p{\n  font-size:13px;\n  font-weight:600;\n  color:#222222;\n  margin:0;\n}\n\n/* ================= ANIMATED UNDERLINE LINK ================= */\n#lume-fulfilment-{{ lume_uid }} pickup-availability .pickup-availability-button{\n  margin-top:6px;\n  font-size:12px;\n  font-weight:400;\n  color:#867E73;\n  position:relative;\n  padding-bottom:2px;\n  background:none;\n  border:0;\n  cursor:pointer;\n  transition: color .2s ease;\n}\n\n/* Animated underline */\n#lume-fulfilment-{{ lume_uid }} pickup-availability .pickup-availability-button::before{\n  content:\"\";\n  position:absolute;\n  left:0;\n  bottom:0;\n  width:0%;\n  height:1px;\n  background:#867E73;\n  transition: width .25s ease;\n}\n#lume-fulfilment-{{ lume_uid }} pickup-availability .pickup-availability-button:hover::before{\n  width:100%;\n}\n\n/* Arrow */\n#lume-fulfilment-{{ lume_uid }} pickup-availability .pickup-availability-button::after{\n  content:\"→\";\n  font-size:12px;\n  margin-left:6px;\n  opacity:.6;\n  display:inline-block;\n  transform:translateX(0);\n  transition: transform .2s ease, opacity .2s ease;\n}\n\n#lume-fulfilment-{{ lume_uid }} pickup-availability .pickup-availability-button:hover{\n  color:#222222;\n}\n#lume-fulfilment-{{ lume_uid }} pickup-availability .pickup-availability-button:hover::after{\n  transform:translateX(3px);\n  opacity:.85;\n}\n\n/* ================= ANIMATION ================= */\n@keyframes lumeFadeUp{\n  from{ opacity:0; transform: translateY(4px); }\n  to{ opacity:1; transform: translateY(0); }\n}\n\n/* ================= MOBILE ================= */\n@media (max-width: 749px){\n  #lume-fulfilment-{{ lume_uid }} .lume-row{\n    grid-template-columns:1fr;\n    gap:8px;\n    padding:16px 16px;\n  }\n  #lume-fulfilment-{{ lume_uid }} .lume-row + .lume-row::before{\n    left:16px;\n    right:16px;\n  }\n  #lume-fulfilment-{{ lume_uid }} .lume-label{\n    padding-top:0;\n    font-size:11px;\n  }\n  #lume-fulfilment-{{ lume_uid }} .lume-secondary{\n    margin-top:4px;\n    font-size:13px;\n    gap:8px;\n  }\n  #lume-fulfilment-{{ lume_uid }} .lume-timer strong{\n    font-size:13px;\n    padding:2px 8px;\n  }\n}\n</style>\n\n<script>\n(function(){\n  const uid = \"{{ lume_uid }}\";\n  const titleEl = document.getElementById(\"ship-title-\" + uid);\n  const subEl   = document.getElementById(\"ship-sub-\" + uid);\n  const timerEl = document.getElementById(\"ship-timer-\" + uid);\n  if (!titleEl || !subEl || !timerEl) return;\n\n  /* =========================\n        TEST MODE\n     =========================\n     enabled: true  -> uses values below (Brisbane time)\n     enabled: true -> uses real Brisbane time\n\n     month: 1–12\n     hour:  0–23\n\n     Examples:\n     - Before cutoff: hour 10\n     - After cutoff:  hour 15\n     - Sunday:        set a date that is Sunday\n     - Public holiday:set month/day to a holiday date\n  */\n  const TEST_MODE = {\n    enabled: false,  // ← turn on to test\n\n    year: 2026,\n    month: 2,\n    day: 25,\n    hour: 14,\n    minute: 0,\n    second: 0\n  };\n\n  const cutoffHour = 14;\n  const cutoffMinute = 30;\n\n  const publicHolidays = new Set([\n    '2025-01-01','2025-01-27','2025-04-18','2025-04-19','2025-04-20','2025-04-21',\n    '2025-04-25','2025-05-05','2025-08-13','2025-10-06','2025-12-25','2025-12-26',\n    '2026-01-01','2026-01-26','2026-04-03','2026-04-04','2026-04-05','2026-04-06',\n    '2026-04-25','2026-05-04','2026-08-12','2026-10-05','2026-12-25','2026-12-26','2026-12-28'\n  ]);\n\n  function getBrisbaneNow(){\n    if (TEST_MODE.enabled) {\n      // Month is 0–11 in JS Dates\n      return new Date(\n        TEST_MODE.year,\n        TEST_MODE.month - 1,\n        TEST_MODE.day,\n        TEST_MODE.hour,\n        TEST_MODE.minute,\n        TEST_MODE.second\n      );\n    }\n    return new Date(new Date().toLocaleString(\"en-US\", { timeZone:\"Australia/Brisbane\" }));\n  }\n\n  function yyyyMmDd(d){\n    const yyyy = d.getFullYear();\n    const mm = String(d.getMonth()+1).padStart(2,'0');\n    const dd = String(d.getDate()).padStart(2,'0');\n    return `${yyyy}-${mm}-${dd}`;\n  }\n\n  const update = () => {\n    const brisNow = getBrisbaneNow();\n    const dStr = yyyyMmDd(brisNow);\n\n    const hr = brisNow.getHours();\n    const min = brisNow.getMinutes();\n    const day = brisNow.getDay();\n\n    const isPastCutoff = (hr > cutoffHour || (hr === cutoffHour && min >= cutoffMinute));\n\n    if (publicHolidays.has(dStr)) {\n      titleEl.textContent = \"Public Holiday\";\n      subEl.textContent = \"Shipping resumes next business day\";\n      timerEl.innerHTML = \"\";\n      return;\n    }\n\n    if (day === 0 || day === 6 || (day === 5 && isPastCutoff)) {\n      titleEl.textContent = \"Ships Monday\";\n      subEl.textContent = \"Secure your spot for Monday’s first dispatch\";\n      timerEl.innerHTML = \"\";\n      return;\n    }\n\n    if (isPastCutoff) {\n      titleEl.textContent = \"Ships Tomorrow\";\n      subEl.textContent = \"Order now for priority dispatch\";\n      timerEl.innerHTML = \"\";\n      return;\n    }\n\n    titleEl.textContent = \"Ships Today\";\n    subEl.textContent = \"Order within the next\";\n\n    const target = new Date(brisNow);\n    target.setHours(cutoffHour, cutoffMinute, 0, 0);\n\n    const diff = Math.max(0, target - brisNow);\n    const hh = Math.floor(diff/36e5);\n    const mm = Math.floor((diff%36e5)/6e4);\n    const ss = Math.floor((diff%6e4)/1e3);\n\n    timerEl.innerHTML = `<strong>${hh}h ${mm}m ${ss}s</strong>`;\n  };\n\n  update();\n  setInterval(update, 1000);\n})();\n</script>",
