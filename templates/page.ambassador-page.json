    "custom_block_masonry_8HRh8w": {
      "type": "custom-block-masonry",
      "blocks": {
        "html_weynBz": {
          "type": "html",
          "name": "AMBASSADOR HTML",
          "settings": {
            "hidem": false,
            "code": "<div class=\"lume-ambassador-wrap\">\n\n  <div class=\"lume-tier-intro\">\n    <h2>Choose Your Ambassador Tier</h2>\n    <p>Choose the ambassador tier that fits how you want to grow with Studio Lume Supplies.</p>\n\n    <div class=\"lume-tier-jump-wrap\">\n      <div class=\"lume-tier-jump\">\n        <a href=\"#lume-collective\">View Collective</a>\n        <a href=\"#lume-elite\">View Elite</a>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"lume-tier-grid\">\n\n    <!-- COLLECTIVE -->\n    <div class=\"lume-tier-card\" id=\"lume-collective\">\n      <div class=\"lume-tier-image\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0637/8795/8356/files/IMG_8354.webp?v=1780068545\" alt=\"LUME Collective\" width=\"1200\" height=\"600\" loading=\"eager\" decoding=\"async\" fetchpriority=\"high\" sizes=\"(max-width: 749px) 100vw, 50vw\">\n      </div>\n\n      <div class=\"lume-tier-content\">\n        <h2>LUME Collective</h2>\n        <p class=\"lume-tier-subtitle\">For artists growing with Studio Lume.</p>\n\n        <div class=\"tier-block\">\n          <h3>\n            <span class=\"tier-heading-icon\" aria-hidden=\"true\">\n              <svg viewbox=\"0 0 24 24\" fill=\"none\">\n                <path d=\"M12 3.5l1.9 4.5 4.9.4-3.7 3.1 1.1 4.7L12 13.8 7.8 16.2l1.1-4.7-3.7-3.1 4.9-.4L12 3.5z\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linejoin=\"round\"></path>\n              </svg>\n            </span>\n            What You Get\n          </h3>\n\n          <ul class=\"icon-list\">\n            <li>\n<strong>15% off storewide</strong> (personal use only)</li>\n            <li>\n<strong>Early access</strong> to sales</li>\n            <li><strong>Occasional surprise gifts</strong></li>\n            <li>Access to <strong>ambassador-only sales</strong>\n</li>\n            <li>Be part of the <strong>Studio Lume ambassador community</strong>\n</li>\n            <li>\n<strong>Want more perks?</strong> Join LUME Elite anytime</li>\n          </ul>\n        </div>\n\n        <div class=\"tier-block\">\n          <h3>\n            <span class=\"tier-heading-icon\" aria-hidden=\"true\">\n              <svg viewbox=\"0 0 24 24\" fill=\"none\">\n                <circle cx=\"12\" cy=\"12\" r=\"8.25\" stroke=\"currentColor\" stroke-width=\"1.5\"></circle>\n                <path d=\"M12 7.8v4.7l3 1.8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n              </svg>\n            </span>\n            What We Need\n          </h3>\n\n          <ul class=\"icon-list muted-bullets\">\n            <li>Add <strong>@studiolumesupplies</strong> to your Instagram bio</li>\n            <li>Tag us when <strong>using our products</strong>\n</li>\n            <li>Be <strong>active and aligned</strong> with the Studio Lume brand</li>\n            <li><strong>No exclusivity required</strong></li>\n          </ul>\n        </div>\n\n        <div class=\"lume-tier-apply\">\n          <button class=\"lume-tier-button lume-collective-apply\" type=\"button\">\n            <span>Apply for Collective</span>\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- ELITE -->\n    <div class=\"lume-tier-card lume-elite-card\" id=\"lume-elite\">\n      <div class=\"lume-elite-badge\">Recommended</div>\n\n      <div class=\"lume-tier-image\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0637/8795/8356/files/46aegrz346sdfg.jpg?v=1775142310&amp;width=1200\" alt=\"LUME Elite\" width=\"1200\" height=\"600\" loading=\"eager\" decoding=\"async\" fetchpriority=\"high\" sizes=\"(max-width: 749px) 100vw, 50vw\">\n      </div>\n\n      <div class=\"lume-tier-content\">\n        <h2>LUME Elite</h2>\n        <p class=\"lume-tier-subtitle\">For the icons building a lash empire.</p>\n\n        <div class=\"tier-block\">\n          <h3>\n            <span class=\"tier-heading-icon\" aria-hidden=\"true\">\n              <svg viewbox=\"0 0 24 24\" fill=\"none\">\n                <path d=\"M12 3.5l1.9 4.5 4.9.4-3.7 3.1 1.1 4.7L12 13.8 7.8 16.2l1.1-4.7-3.7-3.1 4.9-.4L12 3.5z\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linejoin=\"round\"></path>\n              </svg>\n            </span>\n            What You Get\n          </h3>\n\n          <ul class=\"icon-list\">\n            <li>\n<strong>20% off storewide</strong> (personal use only)</li>\n            <li>\n<strong>10% referral code</strong> to share with clients and followers</li>\n            <li>Every 10 referral uses earns a <strong>30% personal reward code</strong>\n</li>\n            <li>\n<strong>Early access</strong> to product launches and sales</li>\n            <li>\n<strong>Surprise PR packages</strong> and occasional gifts</li>\n            <li>Exclusive access to <strong>ambassador-only sales</strong>\n</li>\n            <li>\n<strong>Priority reposting</strong> on our Instagram</li>\n            <li><strong>Exclusive Elite birthday reward</strong></li>\n            <li>\n<strong>Priority consideration</strong> for campaigns and product testing</li>\n          </ul>\n        </div>\n\n        <div class=\"tier-block\">\n          <h3>\n            <span class=\"tier-heading-icon\" aria-hidden=\"true\">\n              <svg viewbox=\"0 0 24 24\" fill=\"none\">\n                <circle cx=\"12\" cy=\"12\" r=\"8.25\" stroke=\"currentColor\" stroke-width=\"1.5\"></circle>\n                <path d=\"M12 7.8v4.7l3 1.8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n              </svg>\n            </span>\n            What We Need\n          </h3>\n\n          <ul class=\"icon-list muted-bullets\">\n            <li>Add <strong>@studiolumesupplies</strong> to your Instagram bio</li>\n            <li>Tag us in <strong>professional content</strong>\n</li>\n            <li>Represent Studio Lume in a <strong>polished, on-brand way</strong>\n</li>\n            <li><strong>No promoting competing lash supply brands</strong></li>\n            <li>Maintain <strong>consistent posting and engagement</strong>\n</li>\n          </ul>\n        </div>\n\n        <div class=\"lume-tier-apply\">\n         <button class=\"lume-tier-button lume-elite-apply\" type=\"button\">\n            <span>Apply for Elite</span>\n          </button>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n</div>\n\n<style>\n.lume-ambassador-wrap{\n  width:100%;\n  font-family:Poppins,sans-serif;\n  color:#222222;\n}\n\n.lume-tier-intro{\n  text-align:center;\n  max-width:720px;\n  margin:0 auto 28px;\n  color:#222222;\n}\n\n.lume-tier-intro h2{\n  font-size:26px;\n  font-weight:500;\n  margin:0 0 8px;\n  line-height:1.2;\n  color:#222222;\n}\n\n.lume-tier-intro p{\n  font-size:13px;\n  line-height:1.7;\n  margin:0;\n  opacity:.75;\n  color:#222222;\n}\n\n.lume-tier-jump-wrap{\n  width:100%;\n  text-align:center;\n  margin-top:14px;\n}\n\n.lume-tier-jump{\n  display:none;\n  gap:12px;\n  align-items:center;\n  justify-content:center;\n}\n\n.lume-tier-jump a{\n  display:inline-flex;\n  align-items:center;\n  justify-content:center;\n  text-align:center;\n  width:140px;\n  min-width:140px;\n  height:42px;\n  padding:0 18px;\n  border:1px solid #cbc4bc;\n  border-radius:999px;\n  text-decoration:none;\n  font-size:13px;\n  font-weight:500;\n  line-height:1;\n  color:#222222;\n  background:#ffffff;\n  box-sizing:border-box;\n  transition:background .2s ease,border-color .2s ease,transform .2s ease;\n}\n\n.lume-tier-jump a:hover{\n  background:#f5f5f5;\n  border-color:#cbc4bc;\n}\n\n.lume-tier-grid{\n  display:grid;\n  grid-template-columns:repeat(2,minmax(0,1fr));\n  gap:28px;\n  align-items:stretch;\n}\n\n.lume-tier-card{\n  position:relative;\n  background:#ffffff;\n  border:1px solid #eee9e4;\n  border-radius:14px;\n  overflow:hidden;\n  display:flex;\n  flex-direction:column;\n  height:100%;\n  box-sizing:border-box;\n  opacity:0;\n  transform:translateY(18px);\n  animation:lumeFadeUp .7s ease forwards;\n  transition:transform .25s ease, box-shadow .25s ease, border-color .25s ease;\n}\n\n.lume-tier-card:nth-child(2){\n  animation-delay:.12s;\n}\n\n.lume-tier-card:hover{\n  transform:translateY(-3px);\n  border-color:#cbc4bc;\n  box-shadow:0 8px 24px rgba(0,0,0,.04);\n}\n\n.lume-elite-card{\n  border-color:#cbc4bc;\n  box-shadow:0 10px 28px rgba(0,0,0,.05);\n}\n\n.lume-elite-badge{\n  position:absolute;\n  top:14px;\n  right:14px;\n  z-index:2;\n  font-size:11px;\n  font-weight:500;\n  padding:5px 10px;\n  border-radius:999px;\n  background:#f5f5f5;\n  border:1px solid #eee9e4;\n  color:#222222;\n  font-family:Poppins,sans-serif;\n}\n\n.lume-tier-image{\n  aspect-ratio:16/8;\n  overflow:hidden;\n  background:#eee9e4;\n}\n\n.lume-tier-image img{\n  width:100%;\n  height:100%;\n  object-fit:cover;\n  display:block;\n}\n\n.lume-tier-content{\n  padding:28px 30px 30px;\n  display:flex;\n  flex-direction:column;\n  flex:1 1 auto;\n}\n\n.lume-tier-content h2{\n  text-align:center;\n  font-size:25px;\n  line-height:1.2;\n  font-weight:500;\n  margin:0;\n  color:#222222;\n  letter-spacing:.01em;\n}\n\n.lume-tier-subtitle{\n  text-align:center;\n  font-size:13px;\n  margin:6px 0 24px;\n  color:#222222;\n  font-style:italic;\n  opacity:.72;\n}\n\n.tier-block{\n  margin-top:20px;\n}\n\n.tier-block h3{\n  display:flex;\n  align-items:center;\n  gap:8px;\n  font-size:16px;\n  font-weight:500;\n  margin:0 0 12px;\n  padding-bottom:8px;\n  border-bottom:1px solid #eee9e4;\n  color:#222222;\n}\n\n.tier-heading-icon{\n  width:16px;\n  height:16px;\n  display:inline-flex;\n  color:#867E73;\n  opacity:.85;\n  flex:0 0 16px;\n}\n\n.tier-heading-icon svg{\n  width:16px;\n  height:16px;\n  display:block;\n}\n\n.icon-list{\n  list-style:none !important;\n  padding:0 !important;\n  margin:0 !important;\n}\n\n.icon-list li{\n  list-style:none !important;\n  position:relative;\n  padding-left:18px;\n  margin-bottom:10px;\n  font-size:13px;\n  line-height:1.7;\n  color:#222222;\n}\n\n.icon-list li::marker{\n  content:\"\";\n}\n\n.icon-list li::before{\n  content:\"\";\n  position:absolute;\n  left:0;\n  top:.72em;\n  width:4px;\n  height:4px;\n  border-radius:50%;\n  background:#cbc4bc;\n  transform:translateY(-50%);\n}\n\n.muted-bullets li::before{\n  width:4px;\n  height:4px;\n  background:#cbc4bc;\n}\n\n.lume-tier-content strong{\n  font-weight:450;\n  color:#222222;\n}\n\n.lume-tier-apply{\n  margin-top:auto;\n  padding-top:20px;\n}\n\n.lume-tier-button{\n  width:100%;\n  background:#aca39a;\n  border:none;\n  border-radius:999px;\n  cursor:pointer;\n  overflow:hidden;\n  padding:0;\n  transition:background .2s ease, transform .15s ease;\n  appearance:none;\n  -webkit-appearance:none;\n}\n\n.lume-tier-button span{\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  width:100%;\n  min-height:46px;\n  padding:16px 20px;\n  font-family:Poppins,sans-serif;\n  font-size:14px;\n  font-weight:300;\n  color:#ffffff;\n  line-height:1;\n  text-align:center;\n  box-sizing:border-box;\n}\n\n.lume-tier-button:hover{\n  background:#aca39a;\n  transform:translateY(-1px);\n}\n\n@keyframes lumeFadeUp{\n  to{\n    opacity:1;\n    transform:translateY(0);\n  }\n}\n\n@media screen and (max-width:989px){\n  .lume-tier-grid{\n    gap:20px;\n  }\n\n  .lume-tier-content{\n    padding:24px 22px 26px;\n  }\n}\n\n@media screen and (max-width:749px){\n  .lume-tier-jump{\n    display:inline-flex;\n    flex-wrap:wrap;\n  }\n\n  .lume-tier-grid{\n    grid-template-columns:1fr;\n    gap:18px;\n  }\n\n  .lume-tier-card{\n    border-radius:12px;\n  }\n\n  .lume-tier-image{\n    aspect-ratio:16/7;\n  }\n\n  .lume-tier-content{\n    padding:22px 18px 24px;\n  }\n\n  .lume-tier-content h2{\n    font-size:22px;\n  }\n\n  .lume-tier-subtitle{\n    font-size:12px;\n    margin-bottom:18px;\n  }\n\n  .tier-block{\n    margin-top:18px;\n  }\n\n  .tier-block h3{\n    font-size:15px;\n    margin-bottom:10px;\n  }\n\n  .icon-list li{\n    font-size:12.5px;\n    line-height:1.65;\n    margin-bottom:9px;\n    padding-left:16px;\n  }\n\n  .lume-tier-button span{\n    min-height:44px;\n    padding:15px 18px;\n    font-size:13.5px;\n  }\n\n  .lume-elite-badge{\n    top:12px;\n    right:12px;\n    font-size:10px;\n    padding:5px 9px;\n  }\n}\n</style>",
