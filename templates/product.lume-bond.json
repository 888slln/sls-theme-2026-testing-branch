        "customc_Nhrbtn": {
          "type": "customc",
          "name": "Tab Slider",
          "settings": {
            "custom_liquid": "<script>\n  const SLIDER_CONFIG = {\n    // --- COLORS & STYLE ---\n    slide_bg: \"#f5f5f5\",\n    slide_text: \"#222222\",\n    border_radius: \"0px\",\n\n    // --- FONT CUSTOMISATION ---\n    h_size: \"0.875rem\",  \n    h_weight: \"700\",     \n    h_spacing: \"0px\",    \n\n    p_size: \"0.875rem\",  \n    p_weight: \"300\",     \n    p_spacing: \"0px\",    \n\n    // --- AUTOMATED TEXT ---\n    Ships_Today_Heading: \"Ships Today\",\n    Ships_Today_Sub: \"Order within the next\", \n    Ships_Tomorrow_Heading: \"Ships Tomorrow\",\n    Ships_Tomorrow_Sub: \"Order now for priority dispatch\",\n    \n    Ships_Monday_Heading: \"Ships Monday\",\n    Ships_Monday_Sub: \"Secure your spot for Monday’s first dispatch\",\n    \n    Holiday_Heading: \"Public Holiday\",\n    Holiday_Sub: \"Shipping resumes next business day\",\n\n    // --- SHIPPING LOGIC ---\n    cutoff_hour: 14, // 2:00 PM\n    cutoff_minute: 30, // 30 Minutes\n    \n    // --- QLD PUBLIC HOLIDAYS ---\n    public_holidays: [\n      '2025-01-01', '2025-01-27', '2025-04-18', '2025-04-19', '2025-04-20', '2025-04-21',\n      '2025-04-25', '2025-05-05', '2025-08-13', '2025-10-06', '2025-12-25', '2025-12-26',\n      '2026-01-01', '2026-01-26', '2026-04-03', '2026-04-04', '2026-04-05', '2026-04-06',\n      '2026-04-25', '2026-05-04', '2026-08-12', '2026-10-05', '2026-12-25', '2026-12-26', '2026-12-28'\n    ],\n\n    test_mode: {\n      enabled: false, \n      date: \"2025-12-27T10:00:00\" \n    }\n  };\n</script>\n\n<div class=\"shipping-announcer-main\" id=\"announcer-box\">\n  <div class=\"announcer-content\" id=\"style-box\">\n    <h3 id=\"dyn-h\"></h3>\n    <p id=\"dyn-p\"></p>\n  </div>\n</div>\n\n<style>\n  .shipping-announcer-main { \n    max-width: 100%; \n    margin: 10px 0; \n    overflow: hidden; \n    position: relative; \n    font-family: inherit; \n  }\n  .announcer-content { \n    padding: 25px 20px; \n    text-align: center; \n    box-sizing: border-box; \n  }\n  \n  .announcer-content h3 { \n    margin: 0 0 5px 0 !important; \n    color: inherit; \n    line-height: 1.2 !important;\n  }\n  .announcer-content p { \n    margin: 0 !important; \n    color: inherit; \n    line-height: 1.4 !important;\n  }\n</style>\n\n<script>\n  (function() {\n    const c = SLIDER_CONFIG;\n    const h = document.getElementById('dyn-h');\n    const p = document.getElementById('dyn-p');\n    const box = document.getElementById('style-box');\n    const wrapper = document.getElementById('announcer-box');\n\n    const update = () => {\n      const now = c.test_mode.enabled ? new Date(c.test_mode.date) : new Date();\n      \n      // Get Brisbane Time\n      const qParts = new Intl.DateTimeFormat('en-CA', {\n        timeZone: 'Australia/Brisbane', \n        year:'numeric', month:'2-digit', day:'2-digit', \n        hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:false\n      }).formatToParts(now);\n      \n      const q = {}; qParts.forEach(({type, value}) => q[type] = value);\n      const brisNow = new Date(now.toLocaleString(\"en-US\", {timeZone: \"Australia/Brisbane\"}));\n      \n      const dStr = `${q.year}-${q.month}-${q.day}`;\n      const hr = parseInt(q.hour);\n      const min = parseInt(q.minute);\n      const day = brisNow.getDay(); \n      \n      const isPastCutoff = (hr > c.cutoff_hour || (hr === c.cutoff_hour && min >= c.cutoff_minute));\n\n      // 1. Weekend Logic\n      if (day === 0 || day === 6 || (day === 5 && isPastCutoff)) {\n        h.innerText = c.Ships_Monday_Heading; \n        p.innerText = c.Ships_Monday_Sub;\n      } \n      // 2. Public Holiday\n      else if (c.public_holidays.includes(dStr)) {\n        h.innerText = c.Holiday_Heading; \n        p.innerText = c.Holiday_Sub;\n      } \n      // 3. After Cutoff Weekday\n      else if (isPastCutoff) {\n        h.innerText = c.Ships_Tomorrow_Heading; \n        p.innerText = c.Ships_Tomorrow_Sub;\n      } \n      // 4. Countdown\n      else {\n        h.innerText = c.Ships_Today_Heading;\n        const target = new Date(brisNow);\n        target.setHours(c.cutoff_hour, c.cutoff_minute, 0, 0);\n        const diff = target - brisNow;\n        const hh = Math.floor(diff/36e5), mm = Math.floor((diff%36e5)/6e4), ss = Math.floor((diff%6e4)/1e3);\n        p.innerHTML = `${c.Ships_Today_Sub} <strong style=\"font-weight:700\">${hh}h : ${mm}m : ${ss}s</strong>`;\n      }\n    };\n\n    // Apply Styles\n    h.style.fontSize = c.h_size; h.style.fontWeight = c.h_weight; h.style.letterSpacing = c.h_spacing;\n    p.style.fontSize = c.p_size; p.style.fontWeight = c.p_weight; p.style.letterSpacing = c.p_spacing;\n    \n    Object.assign(box.style, { background: c.slide_bg, color: c.slide_text });\n    wrapper.style.borderRadius = c.border_radius;\n\n    setInterval(update, 1000); \n    update();\n  })();\n</script>",
            "bm": 15
          }
