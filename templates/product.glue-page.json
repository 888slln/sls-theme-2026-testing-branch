        "customc_Nhrbtn": {
          "type": "customc",
          "name": "Tab Slider",
          "settings": {
            "custom_liquid": "<script>\n  const SLIDER_CONFIG = {\n    // --- COLORS & STYLE ---\n    slide1_bg: \"#f5f5f5\",\n    slide1_text: \"#222222\",\n    slide2_bg: \"#f5f5f5\",\n    slide2_text: \"#222222\",\n    border_radius: \"5px\",\n    scroll_speed: 5000, \n\n    // --- FONT CUSTOMISATION ---\n    h_size: \"0.875rem\",  \n    h_weight: \"700\",     \n    h_spacing: \"0px\",    \n\n    p_size: \"0.875rem\",  \n    p_weight: \"300\",     \n    p_spacing: \"0px\",    \n\n    // --- AUTOMATED TEXT (Slide 1) ---\n    Ships_Today_Heading: \"Ships Today\",\n    Ships_Today_Sub: \"Order within the next\", \n    Ships_Tomorrow_Heading: \"Ships Tomorrow\",\n    Ships_Tomorrow_Sub: \"Order now for priority dispatch\",\n    \n    // Updated weekend text\n    Ships_Monday_Heading: \"Ships Monday\",\n    Ships_Monday_Sub: \"Secure your spot for Monday’s first dispatch\",\n    \n    Holiday_Heading: \"Public Holiday\",\n    Holiday_Sub: \"Shipping resumes next business day\",\n\n    // --- MARKETING TEXT (Slide 2) ---\n    Marketing_Heading: \"Free Shipping Over $50\",\n    Marketing_Sub: \"Stock up on your fave lash supplies!\",\n\n    // --- SHIPPING LOGIC ---\n    cutoff_hour: 14, // 2:00 PM\n    cutoff_minute: 30, // 30 Minutes\n    \n    // --- QLD PUBLIC HOLIDAYS ---\n    public_holidays: [\n      '2025-01-01', '2025-01-27', '2025-04-18', '2025-04-19', '2025-04-20', '2025-04-21',\n      '2025-04-25', '2025-05-05', '2025-08-13', '2025-10-06', '2025-12-25', '2025-12-26',\n      '2026-01-01', '2026-01-26', '2026-04-03', '2026-04-04', '2026-04-05', '2026-04-06',\n      '2026-04-25', '2026-05-04', '2026-08-12', '2026-10-05', '2026-12-25', '2026-12-26', '2026-12-28'\n    ],\n\n    test_mode: {\n      enabled: false, \n      date: \"2025-12-27T10:00:00\" \n    }\n  };\n</script>\n\n<div class=\"shipping-announcer-main\" id=\"announcer-box\">\n  <div class=\"shipping-track\" id=\"mainTrack\">\n    <div class=\"announcer-slide\" data-index=\"0\" id=\"s1-style\">\n      <h3 id=\"dyn-h\"></h3>\n      <p id=\"dyn-p\"></p>\n    </div>\n    <div class=\"announcer-slide\" data-index=\"1\" id=\"s2-style\">\n      <h3 id=\"mkt-h\"></h3>\n      <p id=\"mkt-p\"></p>\n    </div>\n  </div>\n  <div class=\"announcer-dots\">\n    <span class=\"a-dot active\" data-dot=\"0\"></span>\n    <span class=\"a-dot\" data-dot=\"1\"></span>\n  </div>\n</div>\n\n<style>\n  .shipping-announcer-main { max-width: 100%; margin: 10px 0; overflow: hidden; position: relative; font-family: inherit; touch-action: pan-y; }\n  .shipping-track { display: flex; will-change: transform; }\n  .announcer-slide { min-width: 100%; padding: 25px 20px 35px 20px; text-align: center; box-sizing: border-box; flex-shrink: 0; }\n  \n  .announcer-slide h3 { \n    margin: 0 0 5px 0 !important; \n    color: inherit; \n    line-height: 1.2 !important;\n  }\n  .announcer-slide p { \n    margin: 0 !important; \n    color: inherit; \n    line-height: 1.4 !important;\n  }\n\n  .announcer-dots { text-align: center; position: absolute; bottom: 12px; width: 100%; line-height: 0; z-index: 10; }\n  .a-dot { height: 6px; width: 6px; margin: 0 4px; background-color: currentColor; border-radius: 50%; display: inline-block; opacity: 0.2; transition: all 0.3s ease; cursor: pointer; }\n  .a-dot.active { opacity: 0.8; width: 12px; border-radius: 3px; }\n</style>\n\n<script>\n  (function() {\n    const c = SLIDER_CONFIG;\n    const track = document.getElementById('mainTrack');\n    const dots = document.querySelectorAll('.a-dot');\n    let playTimer;\n\n    const move = () => {\n      track.style.transition = \"transform 0.5s ease-in-out\";\n      track.style.transform = \"translateX(-100%)\";\n      setTimeout(() => {\n        track.style.transition = \"none\";\n        track.style.transform = \"translateX(0)\";\n        track.appendChild(track.firstElementChild);\n        const idx = track.firstElementChild.getAttribute('data-index');\n        dots.forEach(d => d.classList.toggle('active', d.getAttribute('data-dot') === idx));\n      }, 500);\n    };\n\n    const resetTimer = () => { clearInterval(playTimer); playTimer = setInterval(move, c.scroll_speed); };\n    dots.forEach(d => d.onclick = () => { move(); resetTimer(); });\n\n    const update = () => {\n      const now = c.test_mode.enabled ? new Date(c.test_mode.date) : new Date();\n      const brisNow = new Date(now.toLocaleString(\"en-US\", {timeZone: \"Australia/Brisbane\"}));\n      \n      const qParts = new Intl.DateTimeFormat('en-CA', {timeZone: 'Australia/Brisbane', year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:false}).formatToParts(now);\n      const q = {}; qParts.forEach(({type, value}) => q[type] = value);\n      \n      const dStr = `${q.year}-${q.month}-${q.day}`;\n      const hr = parseInt(q.hour);\n      const min = parseInt(q.minute);\n      const day = brisNow.getDay(); \n      \n      const h = document.getElementById('dyn-h'), p = document.getElementById('dyn-p');\n      const isPastCutoff = (hr > c.cutoff_hour || (hr === c.cutoff_hour && min >= c.cutoff_minute));\n\n      // 1. Weekend Logic (Fri afternoon, Sat, Sun)\n      if (day === 0 || day === 6 || (day === 5 && isPastCutoff)) {\n        h.innerText = c.Ships_Monday_Heading; \n        p.innerText = c.Ships_Monday_Sub;\n      } \n      // 2. Public Holiday\n      else if (c.public_holidays.includes(dStr)) {\n        h.innerText = c.Holiday_Heading; \n        p.innerText = c.Holiday_Sub;\n      } \n      // 3. After Cutoff Weekday\n      else if (isPastCutoff) {\n        h.innerText = c.Ships_Tomorrow_Heading; \n        p.innerText = c.Ships_Tomorrow_Sub;\n      } \n      // 4. Countdown (Ships Today)\n      else {\n        h.innerText = c.Ships_Today_Heading;\n        const target = new Date(brisNow);\n        target.setHours(c.cutoff_hour, c.cutoff_minute, 0, 0);\n        const diff = target - brisNow;\n        const hh = Math.floor(diff/36e5), mm = Math.floor((diff%36e5)/6e4), ss = Math.floor((diff%6e4)/1e3);\n        p.innerHTML = `${c.Ships_Today_Sub} <strong style=\"font-weight:700\">${hh}h : ${mm}m : ${ss}s</strong>`;\n      }\n    };\n\n    const slides = document.querySelectorAll('.announcer-slide');\n    slides.forEach(s => {\n      const h3 = s.querySelector('h3'); const p = s.querySelector('p');\n      h3.style.fontSize = c.h_size; h3.style.fontWeight = c.h_weight; h3.style.letterSpacing = c.h_spacing;\n      p.style.fontSize = c.p_size; p.style.fontWeight = c.p_weight; p.style.letterSpacing = c.p_spacing;\n    });\n\n    document.getElementById('mkt-h').innerText = c.Marketing_Heading;\n    document.getElementById('mkt-p').innerText = c.Marketing_Sub;\n    Object.assign(document.getElementById('s1-style').style, { background: c.slide1_bg, color: c.slide1_text });\n    Object.assign(document.getElementById('s2-style').style, { background: c.slide2_bg, color: c.slide2_text });\n    document.getElementById('announcer-box').style.borderRadius = c.border_radius;\n\n    setInterval(update, 1000); update(); resetTimer();\n  })();\n</script>",
            "bm": 15
          }
        },
