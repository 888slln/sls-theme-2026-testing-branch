        "custom_liquid": "<div id=\"lume-password-launch\" class=\"lume-password-section\">\n  <div class=\"lume-password-container\">\n    <div class=\"lume-password-card\">\n\n      <div class=\"lume-password-eyebrow\">AMBASSADOR ACCESS</div>\n\n      <h1 class=\"lume-password-heading\">A first look at our new launch</h1>\n\n      <div class=\"lume-password-text\">\n        <p>\n          Our ambassadors have been invited to preview the new Studio Lume website and restock before public release.\n          This private access window is limited.\n        </p>\n      </div>\n\n      <div\n        class=\"lume-password-countdown\"\n        data-launch=\"2026-04-05T18:00:00+10:00\"\n        data-expired-text=\"Now Live\"\n      >\n        <div class=\"lume-countdown-item\">\n          <span class=\"lume-count-num\" data-days>00</span>\n          <span class=\"lume-count-label\">Days</span>\n        </div>\n        <div class=\"lume-countdown-item\">\n          <span class=\"lume-count-num\" data-hours>00</span>\n          <span class=\"lume-count-label\">Hours</span>\n        </div>\n        <div class=\"lume-countdown-item\">\n          <span class=\"lume-count-num\" data-minutes>00</span>\n          <span class=\"lume-count-label\">Minutes</span>\n        </div>\n        <div class=\"lume-countdown-item\">\n          <span class=\"lume-count-num\" data-seconds>00</span>\n          <span class=\"lume-count-label\">Seconds</span>\n        </div>\n      </div>\n\n      <div class=\"lume-password-actions\">\n        <button type=\"button\" class=\"lume-password-toggle\" data-password-toggle>\n          Enter Password\n        </button>\n      </div>\n\n      <div class=\"lume-password-form-wrap\" data-password-panel>\n        {% form 'storefront_password' %}\n          {% if form.errors %}\n            <div class=\"lume-password-message lume-password-error\">\n              {{ form.errors | default_errors }}\n            </div>\n          {% endif %}\n\n          <div class=\"lume-password-input-row\">\n            <input\n              type=\"password\"\n              name=\"password\"\n              class=\"lume-password-input\"\n              placeholder=\"Enter your access password\"\n              autocomplete=\"current-password\"\n            >\n            <button type=\"submit\" class=\"lume-password-submit\">\n              Unlock\n            </button>\n          </div>\n        {% endform %}\n      </div>\n\n      <div class=\"lume-password-bottom-note\">\n        Reserved for Studio Lume ambassadors prior to public launch.\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<style>\n#lume-password-launch {\n  --lume-bg: #ffffff;\n  --lume-mocha: #867e73;\n  --lume-charcoal: #222222;\n  --lume-border: rgba(134, 126, 115, 0.12);\n\n  min-height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: 40px 20px;\n  background: #ffffff;\n}\n\n#lume-password-launch .lume-password-container {\n  width: 100%;\n  max-width: 900px;\n}\n\n#lume-password-launch .lume-password-card {\n  max-width: 560px;\n  margin: 0 auto;\n  padding: 44px 28px 32px;\n  text-align: center;\n  border: 1px solid var(--lume-border);\n  border-radius: 22px;\n  background: #ffffff;\n}\n\n#lume-password-launch .lume-password-eyebrow {\n  display: inline-block;\n  margin-bottom: 14px;\n  padding: 6px 12px;\n  border-radius: 999px;\n  border: 1px solid rgba(134, 126, 115, 0.12);\n  color: var(--lume-mocha);\n  font-size: 9px;\n  line-height: 1;\n  letter-spacing: 0.22em;\n  text-transform: uppercase;\n}\n\n#lume-password-launch .lume-password-heading {\n  margin: 0 auto 10px;\n  max-width: 380px;\n  color: var(--lume-charcoal);\n  font-size: 18px;\n  line-height: 1.45;\n  font-weight: 400;\n}\n\n#lume-password-launch .lume-password-text {\n  max-width: 360px;\n  margin: 0 auto 22px;\n  color: var(--lume-mocha);\n  font-size: 13px;\n  line-height: 1.7;\n}\n\n#lume-password-launch .lume-password-text p {\n  margin: 0;\n}\n\n#lume-password-launch .lume-password-countdown {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 10px;\n  max-width: 420px;\n  margin: 0 auto 22px;\n}\n\n#lume-password-launch .lume-countdown-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 6px;\n  min-height: 88px;\n  padding: 14px 10px;\n  border-radius: 16px;\n  border: 1px solid rgba(134, 126, 115, 0.10);\n  background: #ffffff;\n}\n\n#lume-password-launch .lume-count-num {\n  display: block;\n  font-size: 22px;\n  line-height: 1;\n  color: var(--lume-charcoal);\n  font-weight: 400;\n}\n\n#lume-password-launch .lume-count-label {\n  display: block;\n  font-size: 10px;\n  line-height: 1.2;\n  letter-spacing: 0.12em;\n  color: var(--lume-mocha);\n  text-transform: uppercase;\n}\n\n#lume-password-launch .lume-password-actions {\n  margin-bottom: 0;\n}\n\n#lume-password-launch .lume-password-toggle {\n  padding: 12px 22px;\n  border-radius: 999px;\n  background: var(--lume-mocha);\n  color: #ffffff;\n  font-size: 10px;\n  letter-spacing: 0.14em;\n  text-transform: uppercase;\n  border: none;\n  cursor: pointer;\n}\n\n#lume-password-launch .lume-password-form-wrap {\n  max-height: 0;\n  opacity: 0;\n  overflow: hidden;\n  transition: max-height 0.3s ease, opacity 0.25s ease, margin-top 0.25s ease;\n}\n\n#lume-password-launch.is-open .lume-password-form-wrap {\n  max-height: 220px;\n  opacity: 1;\n  margin-top: 14px;\n}\n\n#lume-password-launch .lume-password-input-row {\n  display: grid;\n  grid-template-columns: 1fr auto;\n  gap: 8px;\n}\n\n#lume-password-launch .lume-password-input {\n  height: 42px;\n  padding: 0 14px;\n  border-radius: 999px;\n  border: 1px solid rgba(134, 126, 115, 0.16);\n  background: #ffffff;\n  color: var(--lume-charcoal);\n}\n\n#lume-password-launch .lume-password-submit {\n  height: 42px;\n  padding: 0 14px;\n  border-radius: 999px;\n  background: var(--lume-charcoal);\n  color: #ffffff;\n  font-size: 10px;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  border: none;\n  cursor: pointer;\n}\n\n#lume-password-launch .lume-password-message {\n  margin-bottom: 10px;\n  color: var(--lume-mocha);\n  font-size: 12px;\n  line-height: 1.5;\n}\n\n#lume-password-launch .lume-password-error {\n  padding: 10px 12px;\n  border-radius: 12px;\n  border: 1px solid rgba(134, 126, 115, 0.12);\n  background: #ffffff;\n}\n\n#lume-password-launch .lume-password-error ul {\n  margin: 0;\n  padding-left: 18px;\n  text-align: left;\n}\n\n#lume-password-launch .lume-password-bottom-note {\n  margin-top: 16px;\n  font-size: 10px;\n  line-height: 1.5;\n  color: var(--lume-mocha);\n}\n\n@media (max-width: 749px) {\n  #lume-password-launch {\n    padding: 18px 12px;\n    align-items: flex-start;\n  }\n\n  #lume-password-launch .lume-password-card {\n    padding: 28px 16px 24px;\n  }\n\n  #lume-password-launch .lume-password-heading {\n    font-size: 16px;\n    max-width: 240px;\n  }\n\n  #lume-password-launch .lume-password-text {\n    font-size: 12px;\n    max-width: 250px;\n  }\n\n  #lume-password-launch .lume-password-countdown {\n    grid-template-columns: repeat(2, 1fr);\n    max-width: 260px;\n  }\n\n  #lume-password-launch .lume-password-input-row {\n    grid-template-columns: 1fr;\n  }\n\n  #lume-password-launch .lume-password-toggle,\n  #lume-password-launch .lume-password-submit {\n    width: 100%;\n  }\n}\n</style>\n\n<script>\n(function () {\n  var section = document.getElementById('lume-password-launch');\n  if (!section) return;\n\n  var btn = section.querySelector('[data-password-toggle]');\n  var panel = section.querySelector('[data-password-panel]');\n  var countdown = section.querySelector('.lume-password-countdown');\n\n  if (btn && panel) {\n    btn.addEventListener('click', function () {\n      var isOpen = section.classList.toggle('is-open');\n      btn.textContent = isOpen ? 'Hide Password Entry' : 'Enter Password';\n    });\n  }\n\n  if (!countdown) return;\n\n  var target = new Date(countdown.getAttribute('data-launch')).getTime();\n  if (isNaN(target)) return;\n\n  function pad(num) {\n    return String(num).padStart(2, '0');\n  }\n\n  function updateCountdown() {\n    var now = new Date().getTime();\n    var diff = target - now;\n\n    if (diff <= 0) {\n      countdown.innerHTML = \"<div class='lume-countdown-item' style='grid-column:1 / -1;'>Now Live</div>\";\n      return;\n    }\n\n    var d = Math.floor(diff / (1000 * 60 * 60 * 24));\n    var h = Math.floor((diff / (1000 * 60 * 60)) % 24);\n    var m = Math.floor((diff / (1000 * 60)) % 60);\n    var s = Math.floor((diff / 1000) % 60);\n\n    var days = section.querySelector('[data-days]');\n    var hours = section.querySelector('[data-hours]');\n    var minutes = section.querySelector('[data-minutes]');\n    var seconds = section.querySelector('[data-seconds]');\n\n    if (days) days.textContent = pad(d);\n    if (hours) hours.textContent = pad(h);\n    if (minutes) minutes.textContent = pad(m);\n    if (seconds) seconds.textContent = pad(s);\n  }\n\n  updateCountdown();\n  setInterval(updateCountdown, 1000);\n})();\n</script>",
