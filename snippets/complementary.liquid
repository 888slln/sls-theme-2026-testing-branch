<div class="complementary-products recommendad-wrapper sls-product-complementary mb{{ blk_st.bm }}" {{ blk_st.shopify_attributes }}>
    <h2 class="rgTxt tc" style="--cl:{{ blk_st.cl }};--fs:{{ blk_st.fs }}px;--fsm:{{ blk_st.fsm }}px;--fw:{{ blk_st.fw }}">{{ blk_st.title }}</h2>
    <product-recommendations data-id="compSlider" data-url="{{ routes.product_recommendations_url }}?section_id={{ sectionId }}&product_id={{ product.id }}&limit={{ blk_st.limit }}&intent=complementary"
        class="grid gspace recomPr rwcols-{{ blk_st.gridmb }} rwcols-md-{{ blk_st.gridtb }} rwcols-lg-{{ blk_st.grid }} recomprSlider swiper" role="list" id="compSlider" style="--grsp:12px;--grspm:8px;"
        data-swiper='{ "slidesPerView":"auto", "loop":false, {% if blk_st.autoplay %}"autoplay":{ "delay":"{{ blk_st.speed | times: 1000 }}" },{% endif %} "navigation":{ "nextEl":".swn{{ section.id }}","prevEl":".swp{{ section.id }}" },"pagination":{ "el":".swpg{{ section.id }}","clickable":false }}'>
        {%- if recommendations.performed and recommendations.products_count > 0 -%}
            <div class="swiper-wrapper">
            {%- for product in recommendations.products limit: blk_st.settings.products_per_page offset: continue -%}
                <div class="swiper-slide gitem tc">
                    <div class="grid_bx">
                    <a class="grid_img mb15" href="{{ product.url | within: collection }}">
                        {{ product.featured_image | image_url: width: product.featured_image.width | image_tag: loading:'lazy', width:product.featured_image.width, height:product.featured_image.height, class:'imgFt primary', sizes:sizes, widths:"180,320,400,560,740" }}
                    </a>
                    <div class="grid_title"><a href="{{ product.url | within: collection }}">{{ product.title }}</a></div>
                    {% unless settings.catalogmode %}<div class="grid_meta mt5">{% render 'product-price', product: product %}</div>{% endunless %}
                    </div>
                </div>
            {%- endfor -%}
            </div>
            {% render 'swiper-navigation', id:section.id, section_st:blk_st %}
        {%- endif -%}
    </product-recommendations>
</div>

<style>
  .sls-product-complementary .rgTxt {
    margin-bottom: 20px;
    letter-spacing: 0;
  }

  .sls-product-complementary product-recommendations {
    width: 100%;
    margin-inline: auto;
  }

  .sls-product-complementary .gspace {
    margin-inline: -6px;
  }

  .sls-product-complementary .gspace .gitem {
    padding-inline: 6px;
  }

  .sls-product-complementary .grid_bx {
    border: 0;
    background: transparent;
  }

  .sls-product-complementary .grid_img {
    padding-bottom: 100%;
    background: #faf9f7;
    margin-bottom: 20px;
  }

  .sls-product-complementary .grid_img .imgFt {
    object-fit: cover;
  }

  .sls-product-complementary .grid_title {
    margin-top: 0;
    font-size: 14px;
    line-height: 1.35;
  }

  .sls-product-complementary .grid_meta {
    margin-top: 10px;
  }

  .sls-product-complementary .grid_meta .pr_price {
    font-size: 13px;
  }

  @media screen and (max-width: 767px) {
    .sls-product-complementary .gspace {
      margin-inline: -5px;
    }

    .sls-product-complementary .gspace .gitem {
      padding-inline: 5px;
    }

    .sls-product-complementary .rgTxt {
      margin-bottom: 14px;
    }
  }
</style>
