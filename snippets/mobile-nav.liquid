{%- liquid
  assign mobile_menu_full_width = true
  if sec_st.mobile_menu_full_width == false
    assign mobile_menu_full_width = false
  endif
  assign mobile_menu_italic = true
  if sec_st.mobile_menu_italic == false
    assign mobile_menu_italic = false
  endif
  assign mobile_menu_font_size = sec_st.mobile_menu_font_size | default: settings.mbNav_ft | default: 13
  assign mobile_menu_font_weight = sec_st.mobile_menu_font_weight | default: settings.mmfw | default: 400
  assign mobile_menu_row_padding = sec_st.mobile_menu_row_padding | default: 15
  assign mobile_menu_speed = sec_st.mobile_menu_speed | default: 380
  assign mobile_menu_stagger = sec_st.mobile_menu_stagger | default: 30
  assign desktop_menu_font_size = sec_st.desktop_menu_font_size | default: settings.navfs | default: mobile_menu_font_size
  assign desktop_menu_font_weight = sec_st.desktop_menu_font_weight | default: settings.navfw | default: mobile_menu_font_weight
  assign mobile_menu_bg = sec_st.mobile_menu_bg | default: '#ffffff'
  assign mobile_menu_text = sec_st.mobile_menu_text | default: '#222222'
  assign mobile_menu_muted = sec_st.mobile_menu_muted | default: '#7a726b'
  assign mobile_menu_border = sec_st.mobile_menu_border | default: '#eee9e4'
  assign desktop_drawer_menu_enabled = false
  if desktop_drawer_enabled
    assign desktop_drawer_menu_enabled = true
  endif
  assign desktop_drawer_position_setting = 'left'
  if desktop_drawer_position != blank
    assign desktop_drawer_position_setting = desktop_drawer_position
  elsif sec_st.desktop_drawer_position != blank
    assign desktop_drawer_position_setting = sec_st.desktop_drawer_position
  endif
  assign desktop_drawer_width_setting = 430
  if desktop_drawer_width != blank
    assign desktop_drawer_width_setting = desktop_drawer_width
  elsif sec_st.desktop_drawer_width != blank
    assign desktop_drawer_width_setting = sec_st.desktop_drawer_width
  endif
  assign desktop_category_menu_setting = blank
  if desktop_category_menu != blank
    assign desktop_category_menu_setting = desktop_category_menu
  elsif sec_st.desktop_catmenu != blank
    assign desktop_category_menu_setting = sec_st.desktop_catmenu
  endif
  if desktop_category_menu_setting == blank and sec_st.catmenu != blank
    assign desktop_category_menu_setting = sec_st.catmenu
  endif
  assign use_desktop_category_menu = false
  if desktop_drawer_menu_enabled and sec_st.enable_desktop_category_menu and desktop_category_menu_setting != blank
    assign use_desktop_category_menu = true
  endif
-%}
<style>
@keyframes lumeMobileRowIn{
  0%{opacity:0; transform:translate3d(0,8px,0);}
  100%{opacity:1; transform:translate3d(0,0,0);}
}
@keyframes lumeMobileRowOut{
  0%{opacity:1; transform:translate3d(0,0,0);}
  100%{opacity:0; transform:translate3d(0,7px,0);}
}
