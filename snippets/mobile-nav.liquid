    opacity:0;
    visibility:hidden;
    pointer-events:none;
    overscroll-behavior:contain;
    transform:translate3d(22px,8px,0) scale(.992);
    transition:transform calc(var(--lume-mmenu-speed) + 70ms) cubic-bezier(.16,1,.3,1), opacity calc(var(--lume-mmenu-speed) + 40ms) cubic-bezier(.16,1,.3,1), visibility 0s linear calc(var(--lume-mmenu-speed) + 70ms);
    z-index:100!important;
    contain:layout paint;
    backface-visibility:hidden;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.st1 ul.subLinks ul.subLinks{
    top:0!important;
    bottom:0!important;
    height:auto!important;
    max-height:100dvh!important;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.st1 ul.subLinks.active.lume-panel-current > li.backto:first-child{
    display:flex!important;
    align-items:center;
    position:sticky!important;
    top:0!important;
    z-index:30!important;
    margin:0!important;
  }
  .mob_nav_wr.lume-desktop-drawer-menu--left .mobNav.st1 ul.subLinks{
    left:0!important;
    right:auto!important;
  }
  .mob_nav_wr.lume-desktop-drawer-menu--right .mobNav.st1 ul.subLinks{
    right:0!important;
    left:auto!important;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.st1 ul.subLinks.active{
    opacity:1;
    visibility:visible;
    pointer-events:auto;
    transform:translate3d(0,0,0) scale(1);
    transition-delay:0s;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.st1 ul.subLinks > li > a{
    justify-content:flex-start;
    text-align:left;
    padding-left:18px!important;
    padding-right:54px!important;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.st1 ul.subLinks > li > a .arw{
    position:absolute;
    right:18px;
    top:50%;
    margin:0!important;
    transform:translateY(-50%) rotate(-90deg);
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.st1 ul.subLinks.lume-panel-ancestor{
    pointer-events:none;
    z-index:99!important;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.st1 ul.subLinks.lume-panel-ancestor > li > a,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.st1 ul.subLinks.lume-panel-ancestor > li.backto,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.st1 ul.subLinks.lume-panel-ancestor > li.help{
    opacity:0;
    visibility:hidden;
    pointer-events:none;
    transform:translate3d(-12px,0,0);
    transition:opacity 160ms cubic-bezier(.16,1,.3,1), transform 200ms cubic-bezier(.16,1,.3,1), visibility 0s linear 200ms;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.lume-has-open-panel > li > a,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.lume-has-open-panel > li.help{
    opacity:0;
    visibility:hidden;
    pointer-events:none;
    transform:translate3d(-12px,0,0);
    transition:opacity 180ms cubic-bezier(.16,1,.3,1), transform 220ms cubic-bezier(.16,1,.3,1), visibility 0s linear 220ms;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.lume-rows-preparing:not(.hide):not(.lume-has-open-panel) > li > a,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.lume-rows-preparing:not(.hide):not(.lume-has-open-panel) > li.help,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-preparing.active:not(.lume-panel-ancestor) > li > a,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-preparing.active:not(.lume-panel-ancestor) > li.backto,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-preparing.active.lume-panel-current > li.backto:first-child,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-preparing.active:not(.lume-panel-ancestor) > li.help{
    opacity:0!important;
    transform:translate3d(0,8px,0)!important;
    animation:none!important;
    backface-visibility:hidden;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-preparing.active.lume-panel-current > li.backto:first-child > span{
    opacity:0!important;
    transform:translate3d(0,8px,0)!important;
    animation:none!important;
    backface-visibility:hidden;
    display:block;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.lume-rows-entering:not(.hide):not(.lume-has-open-panel) > li > a,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.lume-rows-entering:not(.hide):not(.lume-has-open-panel) > li.help,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-entering.active:not(.lume-panel-ancestor) > li > a,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-entering.active:not(.lume-panel-ancestor) > li.backto,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-entering.active.lume-panel-current > li.backto:first-child,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-entering.active:not(.lume-panel-ancestor) > li.help{
    animation:lumeMobileRowIn calc(var(--lume-mmenu-speed) + 90ms) cubic-bezier(.16,1,.3,1) both!important;
    animation-delay:calc(var(--lume-row-index) * var(--lume-mmenu-stagger))!important;
    backface-visibility:hidden;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-entering.active.lume-panel-current > li.backto:first-child > span{
    animation:lumeMobileRowIn calc(var(--lume-mmenu-speed) + 90ms) cubic-bezier(.16,1,.3,1) both!important;
    animation-delay:calc(var(--lume-row-index) * var(--lume-mmenu-stagger))!important;
    backface-visibility:hidden;
    display:block;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.lume-rows-leaving:not(.hide):not(.lume-has-open-panel) > li > a,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav.lume-rows-leaving:not(.hide):not(.lume-has-open-panel) > li.help,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-leaving.active:not(.lume-panel-ancestor) > li > a,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-leaving.active:not(.lume-panel-ancestor) > li.backto,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-leaving.active.lume-panel-current > li.backto:first-child,
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-leaving.active:not(.lume-panel-ancestor) > li.help{
    animation:lumeMobileRowOut 220ms cubic-bezier(.4,0,.2,1) both!important;
    animation-delay:calc((30 - var(--lume-row-index)) * 6ms)!important;
    backface-visibility:hidden;
  }
  .mob_nav_wr.lume-desktop-drawer-menu .mobNav ul.subLinks.lume-rows-leaving.active.lume-panel-current > li.backto:first-child > span{
    animation:lumeMobileRowOut 220ms cubic-bezier(.4,0,.2,1) both!important;
    animation-delay:calc((30 - var(--lume-row-index)) * 6ms)!important;
    backface-visibility:hidden;
    display:block;
  }
}
{% endif %}
</style>

{%- capture mobile_menu -%}
<div class="mob_nav_wr fl f-col hide-lg{% if desktop_drawer_menu_enabled %} lume-desktop-drawer-menu lume-desktop-drawer-menu--{{ desktop_drawer_position_setting }}{% endif %}{% if use_desktop_category_menu %} lume-desktop-category-default{% endif %}" role="navigation" style="--lume-mmenu-width:{% if mobile_menu_full_width %}100vw{% else %}min(390px, 100vw){% endif %};--lume-mmenu-desktop-width:{{ desktop_drawer_width_setting }}px;--lume-mmenu-bg:{{ mobile_menu_bg }};--lume-mmenu-text:{{ mobile_menu_text }};--lume-mmenu-muted:{{ mobile_menu_muted }};--lume-mmenu-border:{{ mobile_menu_border }};--lume-mmenu-font-size:{{ mobile_menu_font_size }}px;--lume-mmenu-font-weight:{{ mobile_menu_font_weight }};--lume-mmenu-desktop-font-size:{{ desktop_menu_font_size }}px;--lume-mmenu-desktop-font-weight:{{ desktop_menu_font_weight }};--lume-mmenu-row-padding:{{ mobile_menu_row_padding }}px;--lume-mmenu-speed:{{ mobile_menu_speed }}ms;--lume-mmenu-stagger:{{ mobile_menu_stagger }}ms;--lume-mmenu-drawer-speed:{{ mobile_menu_speed | plus: 140 }}ms;--lume-mmenu-drawer-fade-speed:240ms;--lume-mmenu-drawer-ease:cubic-bezier(.22,1,.36,1);--lume-mmenu-font-style:{% if mobile_menu_italic %}italic{% else %}normal{% endif %};background-color:{{ mobile_menu_bg }}!important;color:{{ mobile_menu_text }}!important;">
     <div class="mbNavHrd fl">
          {%- render 'sls-account-component', wrapper_class: 'lume-mobile-account', icntyp: '1' -%}
          <div class="lume-mobile-tabs{% if sec_st.catnav or use_desktop_category_menu %} lume-mobile-tabs--has-categories{% endif %}{% if use_desktop_category_menu %} lume-mobile-tabs--desktop-category{% endif %}">
            <a href="#mobNav" class="mnvTtl mbMnink pr{% unless use_desktop_category_menu %} active{% endunless %}">{{ 'sections.navigation.menu' | t }}</a>
            {% if sec_st.catnav %}
              <a href="#mobCtnav" class="mnvTtl mbMnink pr{% if use_desktop_category_menu %} lume-mobile-category-tab{% endif %}">{{ 'sections.navigation.categories' | t }}</a>
            {% endif %}
            {% if use_desktop_category_menu %}<a href="#mobCtnavDesktop" class="mnvTtl mbMnink pr lume-desktop-category-tab active">{{ 'sections.navigation.categories' | t }}</a>{% endif %}
          </div>
          <a href="#closeNav" class="lume-mobile-close closembNav" title="{{ 'sections.navigation.close_menu' | t }}" aria-label="{{ 'sections.navigation.close_menu' | t }}"><svg class="at-icon"><use xlink:href="#icon-close"></use></svg></a>
     </div>
      <ul id="mobNav" class="mobNav fl f-col hide-lg{% if settings.mmsub %} st2{% else %} st1{% endif %}">
      {%- capture arrow -%}
          {% if settings.mmsub %}
            <svg class="at-icon arw ml_auto"><use class="mns" xlink:href="#icon-plus"></use><use xlink:href="#icon-minus"></use></svg>
          {% else %}
            <svg class="at-icon arw right ml_auto"><use xlink:href="#icon-arrow"></use></svg>
          {% endif %}
      {%- endcapture -%}
      {%- capture arrowbk -%}<svg class="at-icon arw left mr20"><use xlink:href="#icon-arrow"></use></svg>{%- endcapture -%}
      {% if sec_st.spnav %}
          {% for link in linklists[sec_st.mbmenu].links %}
              {% render 'mm-mobile-links', link: link, arrow:arrow, arrowbk:arrowbk %}
          {% endfor %}
      {% else %}
          {%- for block in section.blocks -%}
              {% assign blk_st = block.settings %}
              {%- assign label = blk_st.title |  split: '[label' | last  | split: ']' | first | prepend: "nm_lbl" -%}
              {%- capture link_level_1 -%}
                  {% if navType == 'cat' %}
                      {%- assign collection = collections[blk_st.url] -%}
                      {%- assign ttlink = collections[blk_st.url].url -%}
                  {% else %}
                      {%- assign ttlink = blk_st.url -%}
                  {% endif %}
                  <a class="hasSub" href="{% if blk_st.url != blank %}{{ ttlink }}{% else %}#{% endif %}"{% render 'sls-menu-link-attrs', title: blk_st.title %}>
                      {% if sec_st.sicnm and collection.metafields.custom.icon != blank and navType == 'cat' %}
                          {% assign icn_size = sec_st.icnm | plus: 50 %}
                          <img class="icn lazyload mr10" data-src="{{ collection.metafields.custom.icon | image_url: width: icn_size }}" width="{{ sec_st.icnm }}" height="{{ sec_st.icnm }}" alt="{{ collection.title }}" />
                      {% endif %}
                      {% render 'sls-menu-link-title', title: blk_st.title %}
                      {% if blk_st.title contains '[label' %} <span class="lbl {{ label }}">{{ settings[label] }}</span>{% endif %}
                      {{ arrow }}
                  </a>
              {%- endcapture -%}
              {%- if block.type == 'home' -%}
                  <li class="lvl1"><a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t }}</a></li>
              {%- elsif block.type == 'slink' -%}
                  <li class="lvl1">{{ link_level_1 | remove: arrow | remove: 'hasSub' }}</li>
              {%- elsif block.type == 'm1' or block.type == 'm2' or block.type == 'm4' or block.type == 'm5' or block.type == 'dd' -%}
                  {%- if blk_st.title != blank -%}
                      <li class="lvl1 parent">{{ link_level_1 }}
                          <ul class="subLinks close">
                              {% unless settings.mmsub %}
                                  {% assign name = blk_st.title | split:'[label' | first %}
                                  {%- assign backto_collection_url = blank -%}
                                  {%- if ttlink contains '/collections/' -%}
                                      {%- assign backto_collection_handle = ttlink | split: '/collections/' | last | split: '?' | first | split: '#' | first | split: '/' | first -%}
                                      {%- if collections[backto_collection_handle] != blank -%}{%- assign backto_collection_url = ttlink -%}{%- endif -%}
                                  {%- endif -%}
                                  <li class="backto" data-title="{{ name | escape }}"{% if backto_collection_url != blank %} data-url="{{ backto_collection_url | escape }}"{% endif %}>{{ arrowbk }} <span>{{ name }}</span></li>
                              {% endunless %}
                              {% for link in linklists[blk_st.menu].links %}{% render 'mm-mobile-links', link:link, arrow:arrow, arrowbk:arrowbk %}{% endfor %}
                          </ul>
                      </li>
                  {%- endif -%}
              {%- elsif block.type == 'm3' and blk_st.title != blank -%}
                  <li class="lvl1 parent">{{ link_level_1 }}
                      <ul class="subLinks">
                          {%- if blk_st.ttl1 != blank or blk_st.ttl2 != blank or blk_st.ttl3 != blank or blk_st.ttl4 != blank or blk_st.ttl5 != blank -%}
                              {% unless settings.mmsub %}
                                  {% assign name = blk_st.title | split:'[label' | first %}
                                  {%- assign backto_collection_url = blank -%}
                                  {%- if ttlink contains '/collections/' -%}
                                      {%- assign backto_collection_handle = ttlink | split: '/collections/' | last | split: '?' | first | split: '#' | first | split: '/' | first -%}
                                      {%- if collections[backto_collection_handle] != blank -%}{%- assign backto_collection_url = ttlink -%}{%- endif -%}
                                  {%- endif -%}
                                  <li class="backto" data-title="{{ name | escape }}"{% if backto_collection_url != blank %} data-url="{{ backto_collection_url | escape }}"{% endif %}>{{ arrowbk }} <span>{{ name }}</span></li>
                              {% endunless %}
                          {%- endif -%}
                          {% for i in (1..5) %}
                              {% capture bkttl %}{% cycle blk_st.ttl1, blk_st.ttl2, blk_st.ttl3, blk_st.ttl4, blk_st.ttl5 %}{% endcapture %}
                              {%- assign m_3_label = bkttl |  split: '[label' | last  | split: ']' | first | prepend: "nm_lbl" -%}
                              {% if navType == 'cat' %}
                                  {%- assign collection = collections[blk_st.url] -%}
                                  {% capture bkurl %}{% cycle blk_st.url1.url, blk_st.url2.url, blk_st.url3.url, blk_st.url4.url, blk_st.url5.url %}{% endcapture %}
                              {% else %}
                                  {% capture bkurl %}{% cycle blk_st.url1, blk_st.url2, blk_st.url3, blk_st.url4, blk_st.url5 %}{% endcapture %}
                              {% endif %}
                              {% capture bkmenu %}{% cycle blk_st.menu1, blk_st.menu2, blk_st.menu3, blk_st.menu4, blk_st.menu5 %}{% endcapture %}
                              {%- if bkttl != blank -%}
                                  <li>
                                      <a href="{% if bkurl != blank %}{{ bkurl }}{% else %}#{% endif %}" {% if linklists[blk_st.menu1].links != blank %}class="hasSub"{% endif %}>
                                          {{ bkttl | split: '[label' | first }}
                                          {% if bkttl contains '[label' %}<span class="lbl {{ m_3_label }}">{{ settings[m_3_label] }}</span>{% endif %}
                                          {% if linklists[bkmenu].links != blank %}{{ arrow }}{% endif %}
                                      </a>
                                      {% if linklists[bkmenu].links != blank %}
                                          <ul class="subLinks">
                                              {% assign bkname = bkttl | split: '[label' | first %}
                                              {%- assign backto_collection_url = blank -%}
                                              {%- if bkurl contains '/collections/' -%}
                                                  {%- assign backto_collection_handle = bkurl | split: '/collections/' | last | split: '?' | first | split: '#' | first | split: '/' | first -%}
                                                  {%- if collections[backto_collection_handle] != blank -%}{%- assign backto_collection_url = bkurl -%}{%- endif -%}
                                              {%- endif -%}
                                              <li class="backto" data-title="{{ bkname | escape }}"{% if backto_collection_url != blank %} data-url="{{ backto_collection_url | escape }}"{% endif %}>{{ arrowbk }} <span>{{ bkname }}</span></li>
                                              {% for link in linklists[bkmenu].links %}
                                                  <li{% if link.active %} class="active"{% endif %}>
                                                      {%- assign label = link.title |  split: '[label' | last | split: ']' | first | prepend: "nm_lbl" -%}
                                                      <a href="{{ link.url }}">{{ link.title | split: '[label' | first }}{% if link.title contains '[label' %}<span class="lbl {{ label1 }}">{{ settings[label] }}</span>{% endif %}</a>
                                                  </li>
                                              {% endfor %}
                                          </ul>
                                      {%- endif -%}
                                  </li>
                              {%- endif -%}
                          {% endfor %}
                      </ul>
                  </li>
              {%- endif -%}
          {%- endfor -%}
      {%- endif -%}
      {% if sec_st.exttxt1 != blank and sec_st.extlk1 != blank %}
          <li><a href="{{ sec_st.extlk1 }}" style="color:{{ sec_st.extcl1m }}">{{ sec_st.exttxt1 }}</a></li>
      {%- endif -%}
      {% if sec_st.exttxt2 != blank and sec_st.extlk2 != blank %}
          <li><a href="{{ sec_st.extlk2 }}" style="color:{{ sec_st.extcl2m }}">{{ sec_st.exttxt2 }}</a></li>
      {%- endif -%}
      {% if sec_st.help != blank %}<li class="help">{{ sec_st.help }}</li>{% endif %}
      </ul>
    {% if sec_st.catnav %}
      <ul id="mobCtnav" class="mobNav fl f-col hide{% if settings.mmsub %} st2{% else %} st1{% endif %}" style="--icnsz:{{ sec_st.icnm }}px;--icnrad:{{ sec_st.icnrad }}px">
        {% for link in linklists[sec_st.catmenu].links %}{% render 'mb-cat-links', link: link, secSt: section.settings %}{% endfor %}
      </ul>
    {% endif %}
    {% if use_desktop_category_menu %}
      <ul id="mobCtnavDesktop" class="mobNav fl f-col hide{% if settings.mmsub %} st2{% else %} st1{% endif %}" style="--icnsz:{{ sec_st.icnm }}px;--icnrad:{{ sec_st.icnrad }}px">
        {% for link in linklists[desktop_category_menu_setting].links %}{% render 'mb-cat-links', link: link, secSt: section.settings %}{% endfor %}
      </ul>
    {% endif %}
    {% if settings.mlcurrency or settings.mlLang %}<div class="crlnRow mt_auto fl pr">{% render 'currencyLang', ismobile: true %}</div>{% endif %}
</div>
{%- endcapture -%}
{{- mobile_menu | strip_newlines | remove: "  " | remove: "	" -}}
