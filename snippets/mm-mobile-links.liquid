{%- if link.title == 'HideTitle' -%}
    {%- if link.links != blank -%}
        {%- for childlink in link.links -%}
            <li class="lvl-1{% if childlink.active or childlink.child_active %} active{% endif %}">
                {%- assign label_2 = childlink.title |  split: '[label' | last  | split: ']' | first | prepend: "nm_lbl" -%}
                <a href="{{ childlink.url }}" class="snav lvl-1{% if childlink.links != blank %} hasSub{% endif %}"{% if childlink.title contains '[new]' %} target="_blank"{% endif %}{% render 'sls-menu-link-attrs', title: childlink.title %}>{% render 'sls-menu-link-title', title: childlink.title %}{% if childlink.title contains '[label' %}<span class="lbl {{ label_2 }}">{{ settings[label_2] }}</span>{% endif %}{%- if childlink.links != blank -%}{{ arrow }}{%- endif -%}</a>
                {%- if childlink.links != blank -%}
                    <ul class="subLinks">
                        {% unless settings.mmsub %}
                          {% assign cname = childlink.title | split:'[' | first %}
                          {%- assign backto_collection_url = blank -%}
                          {%- if childlink.type == 'collection_link' -%}
                              {%- assign backto_collection_url = childlink.url -%}
                          {%- elsif childlink.url contains '/collections/' -%}
                              {%- assign backto_collection_handle = childlink.url | split: '/collections/' | last | split: '?' | first | split: '#' | first | split: '/' | first -%}
                              {%- if collections[backto_collection_handle] != blank -%}{%- assign backto_collection_url = childlink.url -%}{%- endif -%}
                          {%- endif -%}
                          <li class="backto" data-title="{{ cname | escape }}"{% if backto_collection_url != blank %} data-url="{{ backto_collection_url | escape }}"{% endif %}>{{ arrowbk }} <span>{{ cname }}</span></li>
                        {% endunless %}
                        {%- for lvl3link in childlink.links -%}
                            <li class="lvl-2 {% if lvl3link.active %}active{% endif %}">
                                {%- assign label_3 = lvl3link.title |  split: '[label' | last  | split: ']' | first | prepend: "nm_lbl" -%}
                                <a href="{{ lvl3link.url }}" class="snav lvl-2"{% if lvl3link.title contains '[new]' %} target="_blank"{% endif %}{% render 'sls-menu-link-attrs', title: lvl3link.title %}>{% render 'sls-menu-link-title', title: lvl3link.title %}{% if lvl3link.title contains '[label' %}<span class="lbl {{ label_3 }}">{{ settings[label_3] }}</span>{% endif %}</a>
                            </li>
                        {%- endfor -%}
                    </ul>
                {%- endif -%}
            </li>
        {%- endfor -%}
    {%- endif -%}
{%- else -%}
    <li{% if link.active or link.child_active %} class="active"{% endif %}>
        {%- assign label_1 = link.title |  split: '[label' | last | split: ']' | first | prepend: "nm_lbl" -%}
        <a href="{{ link.url }}" class="snav{% if link.links != blank %} hasSub{% endif %}"{% if link.title contains '[new]' %} target="_blank"{% endif %}{% render 'sls-menu-link-attrs', title: link.title %}>{% render 'sls-menu-link-title', title: link.title %}{% if link.title contains '[label' %}<span class="lbl {{ label_1 }}">{{ settings[label_1] }}</span>{% endif %}{%- if link.links != blank -%}{{ arrow }}{%- endif -%}</a>
        {%- if link.links != blank -%}
            <ul class="subLinks">
                {% unless settings.mmsub %}
                  {% assign name = link.title | split:'[' | first %}
                  {%- assign backto_collection_url = blank -%}
                  {%- if link.type == 'collection_link' -%}
                      {%- assign backto_collection_url = link.url -%}
                  {%- elsif link.url contains '/collections/' -%}
                      {%- assign backto_collection_handle = link.url | split: '/collections/' | last | split: '?' | first | split: '#' | first | split: '/' | first -%}
                      {%- if collections[backto_collection_handle] != blank -%}{%- assign backto_collection_url = link.url -%}{%- endif -%}
                  {%- endif -%}
                  <li class="backto" data-title="{{ name | escape }}"{% if backto_collection_url != blank %} data-url="{{ backto_collection_url | escape }}"{% endif %}>{{ arrowbk }} <span>{{ name }}</span></li>
                {% endunless %}
                {%- for childlink in link.links -%}
                    <li {% if childlink.active or childlink.child_active %}class="active"{% endif %}>
                        {%- assign label_2 = childlink.title |  split: '[label' | last  | split: ']' | first | prepend: "nm_lbl" -%}
                        <a href="{{ childlink.url }}" class="{% if childlink.links != blank %} hasSub{% endif %}"{% if childlink.title contains '[new]' %} target="_blank"{% endif %}{% render 'sls-menu-link-attrs', title: childlink.title %}>{% render 'sls-menu-link-title', title: childlink.title %}{% if childlink.title contains '[label' %}<span class="lbl {{ label_2 }}">{{ settings[label_2] }}</span>{% endif %}{%- if childlink.links != blank -%}{{ arrow }}{%- endif -%}</a>
                        {%- if childlink.links != blank -%}
                            <ul class="subLinks">
                                {% unless settings.mmsub %}
                                  {% assign cname = childlink.title | split:'[' | first %}
                                  {%- assign backto_collection_url = blank -%}
                                  {%- if childlink.type == 'collection_link' -%}
                                      {%- assign backto_collection_url = childlink.url -%}
                                  {%- elsif childlink.url contains '/collections/' -%}
                                      {%- assign backto_collection_handle = childlink.url | split: '/collections/' | last | split: '?' | first | split: '#' | first | split: '/' | first -%}
                                      {%- if collections[backto_collection_handle] != blank -%}{%- assign backto_collection_url = childlink.url -%}{%- endif -%}
                                  {%- endif -%}
                                  <li class="backto" data-title="{{ cname | escape }}"{% if backto_collection_url != blank %} data-url="{{ backto_collection_url | escape }}"{% endif %}>{{ arrowbk }} <span>{{ cname }}</span></li>
                                {% endunless %}
                                {%- for lvl3link in childlink.links -%}
                                <li {% if lvl3link.active %}class="active"{% endif %}>
                                    {%- assign label_3 = lvl3link.title | split: '[label' | last  | split: ']' | first | prepend: "nm_lbl" -%}
                                    <a href="{{ lvl3link.url }}" {% if lvl3link.title contains '[new]' %} target="_blank"{% endif %}{% render 'sls-menu-link-attrs', title: lvl3link.title %}>{% render 'sls-menu-link-title', title: lvl3link.title %}{% if lvl3link.title contains '[label' %}<span class="lbl {{ label_3 }}">{{ settings[label_3] }}</span>{% endif %}</a>
                                </li>
                                {%- endfor -%}
                            </ul>
                        {%- endif -%}
                    </li>
                {%- endfor -%}
            </ul>
        {%- endif -%}
    </li>
{%- endif -%}
