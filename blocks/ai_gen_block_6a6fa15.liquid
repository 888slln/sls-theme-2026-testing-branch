            <h3 class="ai-ambassador-tier-name-{{ ai_gen_id }}">{{ block.settings.collective_title }}</h3>
            <p class="ai-ambassador-tier-tagline-{{ ai_gen_id }}">{{ block.settings.collective_tagline }}</p>
          </div>

