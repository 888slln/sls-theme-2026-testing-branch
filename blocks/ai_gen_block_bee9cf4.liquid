{% doc %}
  @prompt
    make a custom text block, i want to be able to make one line of text have different wights of font and italic and bold and stuff

    so like **text** for bold
    *text* for italic and stuff like that, i also want to be able to adjust top and bottom padding and colour of text., its not working correctly, also let me centre it, perfect now let me adjust the text spacing, do padding top and bottom seperately for mobile and pc, also let me adjust font size for mobile and desktop seperately.

    and for the text editor let me adjust the weight of the font, bold and not bold is not enough i want all options, me me adjust the bold font weight too
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
  }

  .ai-custom-text__wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
    text-align: {{ block.settings.text_align }};
  }

  .ai-custom-text__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size_desktop }}px;
    font-weight: {{ block.settings.font_weight }};
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  .ai-custom-text__content-{{ ai_gen_id }} strong,
  .ai-custom-text__content-{{ ai_gen_id }} b {
    font-weight: {{ block.settings.bold_font_weight }};
  }

  .ai-custom-text__content-{{ ai_gen_id }} em,
  .ai-custom-text__content-{{ ai_gen_id }} i {
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-custom-text-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-custom-text__wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-custom-text__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-custom-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-custom-text__wrapper-{{ ai_gen_id }}">
    {% if block.settings.text != blank %}
      <div class="ai-custom-text__content-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
    {% else %}
      <div class="ai-custom-text__content-{{ ai_gen_id }}" style="color: #aca39a; font-style: italic;">
        Add your text content here. Use the rich text editor to format with bold, italic, and other styles.
      </div>
    {% endif %}
  </div>
</div>

