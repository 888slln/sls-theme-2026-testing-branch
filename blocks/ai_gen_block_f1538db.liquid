{% doc %}
  @prompt
    text with icons 4 wide on desktop and tablet then 2 wide by 2 high on mobile, let me adjust padding of the section and individual items, let me choose icon/svg upload
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @keyframes fadeInTrustBar {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .ai-text-icons-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    animation: fadeInTrustBar 1.2s ease-in-out forwards;
    opacity: 0;
    background-color: {{ block.settings.section_bg }};
  }

  .ai-text-icons-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .ai-text-icons-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.spacing }}px;
    width: 100%;
  }

  .ai-text-icons-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    gap: {{ block.settings.icon_text_spacing }}px;
    padding: {{ block.settings.item_padding }}px;
    border-radius: 8px; /* Optional: adds a soft look to your tech brand */
  }

  .ai-text-icons-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-text-icons-icon-wrapper-{{ ai_gen_id }} img,
  .ai-text-icons-icon-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-text-icons-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-text-icons-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    line-height: 1.3;
  }

  .ai-text-icons-text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-text-icons-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-text-icons-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.spacing_mobile }}px;
    }

    .ai-text-icons-item-{{ ai_gen_id }} {
      padding: {{ block.settings.item_padding_mobile }}px;
    }

    .ai-text-icons-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-text-icons-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-text-icons-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-text-icons-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-icons-container-{{ ai_gen_id }}">
    <div class="ai-text-icons-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign icon_image_key = 'icon_image_' | append: i
          assign title_key = 'title_' | append: i
          assign text_key = 'text_' | append: i

          assign icon_image = block.settings[icon_image_key]
          assign title = block.settings[title_key]
          assign text = block.settings[text_key]
        %}

        <div class="ai-text-icons-item-{{ ai_gen_id }}">
          {% if icon_image != blank %}
            <div class="ai-text-icons-icon-wrapper-{{ ai_gen_id }}">
              <img
                src="{{ icon_image | image_url: width: 200 }}"
                alt="{{ title | escape }}"
                loading="lazy"
                width="{{ block.settings.icon_size }}"
                height="{{ block.settings.icon_size }}"
              >
            </div>
          {% endif %}

          <div class="ai-text-icons-content-{{ ai_gen_id }}">
            {% if title != blank %}
              <div class="ai-text-icons-title-{{ ai_gen_id }}">{{ title }}</div>
            {% endif %}

            {% if text != blank %}
              <div class="ai-text-icons-text-{{ ai_gen_id }}">{{ text }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Text with icons",
  "settings": [
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Item Styling"
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Internal item padding",
      "min": -50,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "item_padding_mobile",
      "label": "Internal item padding (mobile)",
      "min": -50,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing between items",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "label": "Spacing (mobile)",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_text_spacing",
      "label": "Icon to text spacing",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Icon size (mobile)",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background"
    },
    {
      "type": "range",
      "id": "icon_border_radius",
      "label": "Icon border radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Font size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Font size (mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#222222"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Font size",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Font size (mobile)",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color",
      "default": "#222222"
    },
    {
      "type": "header", "content": "Item 1"
    },
    { "type": "image_picker", "id": "icon_image_1", "label": "Icon" },
    { "type": "inline_richtext", "id": "title_1", "label": "Title", "default": "Free shipping" },
    { "type": "inline_richtext", "id": "text_1", "label": "Text", "default": "On orders over $199" },
    {
      "type": "header", "content": "Item 2"
    },
    { "type": "image_picker", "id": "icon_image_2", "label": "Icon" },
    { "type": "inline_richtext", "id": "title_2", "label": "Title", "default": "Fast delivery" },
    { "type": "inline_richtext", "id": "text_2", "label": "Text", "default": "2-3 business days" },
    {
      "type": "header", "content": "Item 3"
    },
    { "type": "image_picker", "id": "icon_image_3", "label": "Icon" },
    { "type": "inline_richtext", "id": "title_3", "label": "Title", "default": "Secure payment" },
    { "type": "inline_richtext", "id": "text_3", "label": "Text", "default": "100% secure checkout" },
    {
      "type": "header", "content": "Item 4"
    },
    { "type": "image_picker", "id": "icon_image_4", "label": "Icon" },
    { "type": "inline_richtext", "id": "title_4", "label": "Title", "default": "Easy returns" },
    { "type": "inline_richtext", "id": "text_4", "label": "Text", "default": "30-day return policy" }
  ],
  "presets": [
    {
      "name": "Text with icons"
    }
  ]
}
{% endschema %}
