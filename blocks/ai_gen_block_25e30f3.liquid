    { "type": "header", "content": "Overlay" },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#222222"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },

    { "type": "header", "content": "Animation" },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable animation",
      "default": true,
      "info": "Subtle zoom effect on background media"
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Animation duration",
      "min": 5,
      "max": 20,
      "step": 5,
