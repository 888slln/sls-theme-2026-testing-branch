{% doc %}
  @prompt
    make a hero banner, where i can put a image for either mobile and desktop and it changes images depending on the device and size.

    i also want a colour overlay option on it.

    add a parralax effect to., parralax effect is broken, let me turn it off and on.

    let me adjust height and width of both mobile and desktop hero image size.

    let me centre images, can you make a on and off setting where it locks to the size of the image no matter the screen size

    make the entire part a clickable link, when the lock to image size is enables make sure it locks the sides to the edge instead, if its locked to image size let me adjust heght too with a option
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
    overflow: hidden;
  }

  .ai-hero-banner-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    text-decoration: none;
    cursor: pointer;
  }

  .ai-hero-banner-link-{{ ai_gen_id }}:focus {
    outline: 2px solid #222222;
    outline-offset: 2px;
  }

  .ai-hero-banner-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
  }

  .ai-hero-banner-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.lock_to_image_size %}
      height: {{ block.settings.locked_desktop_height }}px;
    {% else %}
      height: {{ block.settings.desktop_height }}px;
    {% endif %}
    overflow: hidden;
    {% if block.settings.center_image %}
      display: flex;
      align-items: center;
      justify-content: center;
    {% endif %}
  }

  .ai-hero-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    {% if block.settings.center_image %}
      object-position: center;
    {% endif %}
    display: block;
  }

  {% if block.settings.lock_to_image_size %}
    .ai-hero-banner-image-{{ ai_gen_id }} {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
  {% endif %}

  .ai-hero-banner-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
    z-index: 1;
  }

  .ai-hero-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    {% if block.settings.lock_to_image_size %}
      height: {{ block.settings.locked_desktop_height }}px;
    {% else %}
      height: {{ block.settings.desktop_height }}px;
    {% endif %}
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #222222;
    text-align: center;
    pointer-events: none;
  }

  {% if block.settings.enable_parallax %}
    .ai-hero-banner-parallax-{{ ai_gen_id }} {
      transform: translateY(0);
      transition: transform 0.1s ease-out;
      will-change: transform;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-hero-banner-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-banner-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-banner-image-wrapper-{{ ai_gen_id }} {
      {% if block.settings.lock_to_image_size %}
        height: {{ block.settings.locked_mobile_height }}px;
      {% else %}
        height: {{ block.settings.mobile_height }}px;
      {% endif %}
    }

    .ai-hero-banner-placeholder-{{ ai_gen_id }} {
      {% if block.settings.lock_to_image_size %}
        height: {{ block.settings.locked_mobile_height }}px;
      {% else %}
        height: {{ block.settings.mobile_height }}px;
      {% endif %}
    }
  }
{% endstyle %}

<hero-banner-{{ ai_gen_id }}
  class="ai-hero-banner-{{ ai_gen_id }}"
  data-parallax="{{ block.settings.enable_parallax }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.banner_link != blank %}
    <a
      href="{{ block.settings.banner_link }}"
      class="ai-hero-banner-link-{{ ai_gen_id }}"
      aria-label="Hero banner link"
    >
  {% else %}
    <div class="ai-hero-banner-link-{{ ai_gen_id }}">
  {% endif %}

    <div class="ai-hero-banner-container-{{ ai_gen_id }}">
      <div class="ai-hero-banner-desktop-{{ ai_gen_id }}">
        <div class="ai-hero-banner-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.desktop_image %}
            <img
              src="{{ block.settings.desktop_image | image_url: width: 2400 }}"
              alt="{{ block.settings.desktop_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.desktop_image.width }}"
              height="{{ block.settings.desktop_image.height }}"
              class="ai-hero-banner-image-{{ ai_gen_id }} {% if block.settings.enable_parallax %}ai-hero-banner-parallax-{{ ai_gen_id }}{% endif %}"
            >
          {% else %}
            <div class="ai-hero-banner-placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
              <div class="ai-hero-banner-empty-state-{{ ai_gen_id }}">
                Add a desktop image
              </div>
            </div>
          {% endif %}
          {% if block.settings.enable_overlay %}
            <div class="ai-hero-banner-overlay-{{ ai_gen_id }}"></div>
          {% endif %}
        </div>
      </div>

      <div class="ai-hero-banner-mobile-{{ ai_gen_id }}">
        <div class="ai-hero-banner-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.mobile_image %}
            <img
              src="{{ block.settings.mobile_image | image_url: width: 800 }}"
              alt="{{ block.settings.mobile_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.mobile_image.width }}"
              height="{{ block.settings.mobile_image.height }}"
              class="ai-hero-banner-image-{{ ai_gen_id }} {% if block.settings.enable_parallax %}ai-hero-banner-parallax-{{ ai_gen_id }}{% endif %}"
            >
          {% elsif block.settings.desktop_image %}
            <img
              src="{{ block.settings.desktop_image | image_url: width: 800 }}"
              alt="{{ block.settings.desktop_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.desktop_image.width }}"
              height="{{ block.settings.desktop_image.height }}"
              class="ai-hero-banner-image-{{ ai_gen_id }} {% if block.settings.enable_parallax %}ai-hero-banner-parallax-{{ ai_gen_id }}{% endif %}"
            >
          {% else %}
            <div class="ai-hero-banner-placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
              <div class="ai-hero-banner-empty-state-{{ ai_gen_id }}">
                Add a mobile image
              </div>
            </div>
          {% endif %}
          {% if block.settings.enable_overlay %}
            <div class="ai-hero-banner-overlay-{{ ai_gen_id }}"></div>
          {% endif %}
        </div>
      </div>
    </div>

  {% if block.settings.banner_link != blank %}
    </a>
  {% else %}
    </div>
  {% endif %}
</hero-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.parallaxEnabled = this.dataset.parallax === 'true';
        this.parallaxImage = null;
        this.ticking = false;
      }

      connectedCallback() {
        if (this.parallaxEnabled) {
          this.parallaxImage = this.querySelector('.ai-hero-banner-parallax-{{ ai_gen_id }}');
          if (this.parallaxImage) {
            this.handleScroll = this.handleScroll.bind(this);
            window.addEventListener('scroll', this.handleScroll, { passive: true });
            this.handleScroll();
          }
        }
      }

      disconnectedCallback() {
        if (this.parallaxEnabled && this.parallaxImage) {
          window.removeEventListener('scroll', this.handleScroll);
        }
      }

      handleScroll() {
        if (!this.ticking) {
          window.requestAnimationFrame(() => {
            this.updateParallax();
            this.ticking = false;
          });
          this.ticking = true;
        }
      }

      updateParallax() {
        if (!this.parallaxImage) return;

        const rect = this.getBoundingClientRect();
        const windowHeight = window.innerHeight;

        if (rect.top < windowHeight && rect.bottom > 0) {
          const scrolled = windowHeight - rect.top;
          const rate = scrolled * 0.3;
          this.parallaxImage.style.transform = `translateY(${rate}px)`;
        }
      }
    }

    customElements.define('hero-banner-{{ ai_gen_id }}', HeroBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Hero banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Height",
      "min": 200,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 600,
      "info": "Used when lock to image size is disabled"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400,
      "info": "Used when lock to image size is disabled"
    },
    {
      "type": "header",
      "content": "Image display"
    },
    {
      "type": "checkbox",
      "id": "center_image",
      "label": "Center image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "lock_to_image_size",
      "label": "Lock to image size",
      "default": false,
      "info": "Image will fit within the height below while maintaining aspect ratio"
    },
    {
      "type": "range",
      "id": "locked_desktop_height",
      "label": "Locked desktop height",
      "min": 200,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 600,
      "info": "Used when lock to image size is enabled"
    },
    {
      "type": "range",
      "id": "locked_mobile_height",
      "label": "Locked mobile height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400,
      "info": "Used when lock to image size is enabled"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Enable overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#222222"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Parallax effect"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "Enable parallax",
      "default": false
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
