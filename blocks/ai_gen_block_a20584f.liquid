{% doc %}
  @prompt
    text with icons, side by side on pc and stacked on mobile, 3 blocks, add box backround and box edge roundness and colour, let me adjust the left and right padding on the box style too, its going from edge to edge i want it to not do that, add top and bottom padding for the section for desktop, let me do custom icon
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-text-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    padding-left: {{ block.settings.container_padding_left }}px;
    padding-right: {{ block.settings.container_padding_right }}px;
  }

  .ai-icon-text-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.gap }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-icon-text-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    gap: {{ block.settings.item_gap }}px;
    background-color: {{ block.settings.box_bg_color }};
    border-radius: {{ block.settings.box_border_radius }}px;
    padding-top: {{ block.settings.box_padding_top }}px;
    padding-bottom: {{ block.settings.box_padding_bottom }}px;
    padding-left: {{ block.settings.box_padding_left }}px;
    padding-right: {{ block.settings.box_padding_right }}px;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    background-color: {{ block.settings.icon_bg_color }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    flex-shrink: 0;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.6);
    height: calc({{ block.settings.icon_size }}px * 0.6);
    fill: {{ block.settings.icon_color }};
  }

  .ai-icon-text-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-icon-text-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    line-height: 1.3;
  }

  .ai-icon-text-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-text-container-{{ ai_gen_id }} {
      padding-top: {{ block.settings.section_padding_top_mobile }}px;
      padding-bottom: {{ block.settings.section_padding_bottom_mobile }}px;
      padding-left: {{ block.settings.container_padding_left_mobile }}px;
      padding-right: {{ block.settings.container_padding_right_mobile }}px;
    }

    .ai-icon-text-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-icon-text-item-{{ ai_gen_id }} {
      padding-top: {{ block.settings.box_padding_top_mobile }}px;
      padding-bottom: {{ block.settings.box_padding_bottom_mobile }}px;
      padding-left: {{ block.settings.box_padding_left_mobile }}px;
      padding-right: {{ block.settings.box_padding_right_mobile }}px;
    }

    .ai-icon-text-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-icon-text-icon-wrapper-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.icon_size_mobile }}px * 0.6);
      height: calc({{ block.settings.icon_size_mobile }}px * 0.6);
    }

    .ai-icon-text-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-icon-text-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }
  }
{% endstyle %}

<icon-text-blocks-{{ ai_gen_id }} class="ai-icon-text-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-text-grid-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign title_key = 'title_' | append: i
        assign description_key = 'description_' | append: i
        assign icon_key = 'icon_' | append: i
        assign custom_svg_key = 'custom_svg_' | append: i

        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
        assign icon = block.settings[icon_key]
        assign custom_svg = block.settings[custom_svg_key]
      %}

      <div class="ai-icon-text-item-{{ ai_gen_id }}">
        <div class="ai-icon-text-icon-wrapper-{{ ai_gen_id }}">
          {% if icon == 'custom' and custom_svg != blank %}
            {{ custom_svg }}
          {% else %}
            {% case icon %}
              {% when 'shipping' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="15" height="13"></rect>
                  <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                  <circle cx="5.5" cy="18.5" r="2.5"></circle>
                  <circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
              {% when 'returns' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="1 4 1 10 7 10"></polyline>
                  <polyline points="23 20 23 14 17 14"></polyline>
                  <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"></path>
                </svg>
              {% when 'support' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
              {% when 'secure' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
              {% when 'quality' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                </svg>
              {% when 'gift' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 12 20 22 4 22 4 12"></polyline>
                  <rect x="2" y="7" width="20" height="5"></rect>
                  <line x1="12" y1="22" x2="12" y2="7"></line>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                </svg>
              {% when 'check' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% when 'heart' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="16" x2="12" y2="12"></line>
                  <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
            {% endcase %}
          {% endif %}
        </div>

        <div class="ai-icon-text-content-{{ ai_gen_id }}">
          {% if title != blank %}
            <h3 class="ai-icon-text-title-{{ ai_gen_id }}">{{ title }}</h3>
          {% endif %}
          {% if description != blank %}
            <p class="ai-icon-text-description-{{ ai_gen_id }}">{{ description }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</icon-text-blocks-{{ ai_gen_id }}>

<script>
  (function() {
    class IconTextBlocks{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('icon-text-blocks-{{ ai_gen_id }}', IconTextBlocks{{ ai_gen_id }});
  })();
</script>

