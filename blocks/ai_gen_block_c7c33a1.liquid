      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "outer_margin_bottom_desktop",
      "label": "Outer bottom margin desktop",
      "min": -150,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "outer_margin_top_mobile",
