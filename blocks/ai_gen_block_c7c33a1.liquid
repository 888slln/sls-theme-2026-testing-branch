      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "spacing_bottom_mobile",
      "label": "Inner bottom spacing mobile",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 16
