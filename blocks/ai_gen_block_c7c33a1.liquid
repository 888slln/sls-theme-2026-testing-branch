      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom_desktop",
      "label": "Inner bottom spacing desktop",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "default": 20
