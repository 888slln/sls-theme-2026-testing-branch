      "min": -100,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "outer_margin_bottom_mobile",
      "label": "Outer bottom margin mobile",
      "min": -100,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom inline text"
    }
  ]
}
{% endschema %}
