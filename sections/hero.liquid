        },
        {
            "type": "range",
            "id": "hit",
            "label": "Desktop",
            "default":600,
            "min": 100,
            "max": 1000,
            "step": 10
        },
        {
            "type": "range",
            "id": "hitt",
            "label": "Tablet",
            "default":500,
            "min": 100,
            "max": 900,
            "step": 10
        },
        {
            "type": "range",
            "id": "hitm",
            "label": "Mobile",
            "default":400,
            "min": 100,
            "max": 900,
            "step": 10
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "Image",
            "info": "Recommended width 2000px and height as per above desktop height"
        },
        {
            "type": "image_picker",
            "id": "imagem",
            "label": "Mobile Image",
            "info": "Recommended width 750px and height as per above mobile height. If mobile image is blank, dekstop image will be used."
        },
       {
            "type": "color",
            "id": "overlay",
            "label": "Image Overlay",
            "default": "#222222"
        },
        {
            "type": "range",
            "id": "overlay_op",
            "min": 0,
            "max": 1,
            "step": 0.1,
            "label": "Overlay Opacity",
            "unit": "%",
            "default": 0
        },
        {
            "type": "header",
            "content": "Image Blur ==="
        },
        {
            "type": "checkbox",
            "id": "blur",
