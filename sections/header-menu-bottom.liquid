{%- liquid
    assign sec_st = section.settings
    assign desktop_drawer_enabled = true
    if sec_st.enable_desktop_drawer_menu == false
        assign desktop_drawer_enabled = false
    endif
    assign desktop_drawer_position = sec_st.desktop_drawer_position | default: 'left'
    assign desktop_hamburger_style = sec_st.desktop_hamburger_style | default: 'plain'
    assign desktop_drawer_width = sec_st.desktop_drawer_width | default: 430
    assign sticky_mobile_type = sec_st.sticky_type_mobile | default: 'inherit'
    if sticky_mobile_type == 'inherit'
        assign sticky_mobile_type = sec_st.sticky_type
    endif

    assign cnt_width = settings.cntwd | append: 'px'
    if sec_st.sw
        assign cnt_width = '100vw'
    endif

    assign is_rtl = false
    assign list_rtl = 'ar,dv,ha,he,ku,fa,ur,ug' | split: ','
    assign pm_left = 'left'
    assign pm_right = 'right'
    if list_rtl contains request.locale.iso_code or settings.rtl
        assign is_rtl = true
        assign pm_left = 'right'
        assign pm_right = 'left'
    endif

    assign logo = sec_st.logo
    assign istrnsparent = false
    assign page_type = request.page_type
    if page_type == 'index' and sec_st.trhead
        assign istrnsparent = true
    elsif page_type == 'collection' and sec_st.trheadcl
        assign istrnsparent = true
    elsif page_type == 'blog' and sec_st.trheadbg
        assign istrnsparent = true
    elsif page_type == 'article' and sec_st.trheadar and article.image != blank
        assign istrnsparent = true
    endif
    if istrnsparent
        assign logo = sec_st.trLogo | default: logo
    endif
-%}

{%- style -%}
     .hdr_bottom { --hdrHt:{{ sec_st.ht }}px;--hdrHtm:{{ sec_st.htm }}px;--hdrSp:{{ sec_st.head_space }}px;--logowd:{{ sec_st.logowd }}px;--logowdm:{{ sec_st.logowdm }}px;
     {%- if sec_st.hdrbd -%}border-bottom:1px solid {{ sec_st.hdrbd_cl }}; {%- endif -%}
     {%- if sec_st.bgimg != blank -%}
        background:{{ sec_st.bg }} url({{ sec_st.bgimg | image_url: width:sec_st.bgimg.width }}) {{ sec_st.bgrepeat }} {{ sec_st.bgposition | replace:"_", " " }}/{{ sec_st.bgsize }};
    {%- elsif sec_st.bgg != blank -%}
        background:{{ sec_st.bgg }};
    {%- else -%}
        background-color:{{ sec_st.bg }};
     {%- endif -%}
    --cl:{{ sec_st.cl }}; --clh:{{ sec_st.clh }}; --icns:{{ sec_st.icon }}px; --icnsm:16px; --fs:{{ sec_st.fs }}px;
    --lume-desktop-menu-font-size:{{ sec_st.desktop_menu_font_size | default: settings.navfs }}px;
    --lume-desktop-menu-font-weight:{{ sec_st.desktop_menu_font_weight | default: settings.navfw }};
    --lume-sticky-compact:{{ sec_st.sticky_compact | default: 12 }}px;
    --lume-sticky-logo-scale:{{ sec_st.sticky_logo_scale | default: 78 | times: 0.01 }};
    --lume-sticky-icon-scale:{{ sec_st.sticky_icon_scale | default: 96 | times: 0.01 }};
    --lume-sticky-bg-alpha:{{ sec_st.sticky_bg_opacity | default: 74 | times: 0.01 }};
    --lume-sticky-blur:{{ sec_st.sticky_blur | default: 14 }}px;
    --lume-sticky-shadow-alpha:{{ sec_st.sticky_shadow_opacity | default: 8 | times: 0.01 }};
    --lume-sticky-scroll-distance:{{ sec_st.sticky_scroll_distance | default: 72 }}px;
    --lume-sticky-transition:{{ sec_st.sticky_transition | default: 260 }}ms;
  }

    {%- if sec_st.cntlogo -%}
      .mbnavCol { min-width:35px; margin-{{ pm_left }}:-5px; }
    {%- else -%}
      .navToggle { margin-{{ pm_right }}:-5px; }
    {%- endif -%}

    .searchinline .search .ad_inputs { max-width:250px;}

  @media only screen and (max-width:1024px){
    .main-search { order:3; width:100%; flex:auto; margin:5px 0 0; }
    {%- if sec_st.cntlogo -%}
      .icons-col { flex:1; }
    {%- endif -%}
  }

  {%- if sec_st.hdrStyle == '3' -%}
  #header .crlgTtl { font-size:{{ settings.navfs }}px; font-weight:{{ settings.navfw }};  {% if settings.nav_case %} text-transform: uppercase; {% endif %} font-family:var(--{{ settings.navft }}); }
  #header .crlgTtl { color:var(--cl); }
  #header .crlgTtl:after { background-color:var(--cl); }
  {%- endif -%}

  {%- if sec_st.icntyp == '3' -%}
  .cartCount.pp {margin: -2upx 0 0 4px;}
  {%- endif -%}

      #header .crlgTtl,
      #header .social_icons a { color:var(--cl); font-weight:{{settings.navfw}};}
      #header .crlgTtl:after { background-color:var(--cl); }
      .hdSearch { max-width:280px; }
      #main_nav.f-jcs > li:first-child > a { padding-left:0; }

  {%- if istrnsparent -%}
      .hdr_wrap:not(.sticky_hdr) { position:absolute; left:0; right:0; }
      .hdr_wrap.sticky_hdr, .hdr_wrap.header-hidden { position:fixed; }
      html:not(.searchact) .hdr_wrap:not(.sticky_hdr,:hover) { background-color:transparent; border-color:transparent; }
      .hdr_wrap:not(.sticky_hdr):not(:hover) .hdicon,
      .hdr_wrap:not(.sticky_hdr):not(:hover) .lvl1 > a,
      .hdr_wrap:not(.sticky_hdr):not(:hover) .crlgTtl { color:{{ sec_st.thcl }}!important; }
      .hdr_wrap:not(.sticky_hdr):not(:hover) .stlogo,
      .hdr_wrap.sticky_hdr .trlogo,
      .hdr_wrap:hover .trlogo { display:none !important; }
      .hdr_wrap:not(.sticky_hdr):not(:hover) #main_navwr { background-color:transparent; border:0 none; }
      .hdr_wrap:hover #header, .searchact #header { background:var(--hdrbg); }
      .hdr_wrap .searchDrawer { top:var(--hdrHtm); }
        @media only screen and (min-width:1024px){
          .hdr_wrap .searchDrawer { top:var(--hdrHt); }
        }
      #main_navwr { transition: all 0.2s ease-in-out; }
      #PageContainer { --hdht:{{ sec_st.ht | plus:40 }}px;--hdhtm:{{ sec_st.htm }}px; }
  {%- endif -%}

  .leftcol .s_res {width:400px !important}

{%- endstyle -%}

{%- capture logo -%}
<div class="header-logo{% if sec_st.mobile_sticky_logo != blank %} header-logo--mobile-sticky-alt{% endif %}">
  <a href="{{ routes.root_url }}" itemprop="url" class="hdr_logo_lnk" title="{{ shop.name }}">
    {%- assign logo_alt = logo.alt | default: shop.name | escape -%}
    {%- capture sizes -%}(max-width: {{ sec_st.logowd | times: 2 }}px) 50vw, {{ sec_st.logowd }}px{%- endcapture -%}
    {%- capture widths -%}{{ sec_st.logowd }}, {{ sec_st.logowd | times: 1.5 | round }}, {{ sec_st.logowd | times: 2 }}{% endcapture -%}
    {%- if istrnsparent and logo != blank -%}
        {%- assign trlogo_ht = sec_st.logowd | divided_by: logo.aspect_ratio -%}
        {{- logo | image_url: width: 600 | image_tag: class: 'imgAt trlogo db fw700', widths: widths, height: trlogo_ht, width: sec_st.logowd, alt: logo_alt, sizes: sizes, preload: true -}}
    {%- endif -%}
    {%- if sec_st.logo != blank -%}
        {%- assign logo_ht = sec_st.logowd | divided_by: sec_st.logo.aspect_ratio -%}
        {{- sec_st.logo | image_url: width: 600 | image_tag: class: 'imgAt stlogo db fw700', widths: widths, height: logo_ht, width: sec_st.logowd, alt: logo_alt, sizes: sizes, preload: true -}}
    {%- else -%}
        <span class="stlogo">{{ shop.name }}</span>
    {%- endif -%}
    {%- if sec_st.mobile_sticky_logo != blank -%}
        {%- assign mobile_sticky_logo_alt = sec_st.mobile_sticky_logo.alt | default: logo_alt | escape -%}
        {%- assign mobile_sticky_logo_ht = sec_st.logowd | divided_by: sec_st.mobile_sticky_logo.aspect_ratio -%}
        {{- sec_st.mobile_sticky_logo | image_url: width: 600 | image_tag: class: 'imgAt mobile-sticky-logo db fw700', widths: widths, height: mobile_sticky_logo_ht, width: sec_st.logowd, alt: mobile_sticky_logo_alt, sizes: sizes, preload: true -}}
    {%- endif -%}
  </a>
</div>
{%- endcapture -%}

{%- capture promo -%}
    {%- if sec_st.promo_head != blank or sec_st.promo_text != blank -%}
      <div class="fl f-aic promo_txt hide-sm hide-md" style="--icns:{{ sec_st.prisz }}px">
        {%- if sec_st.prico != blank -%}
          {%- capture prico_width -%}{{ sec_st.prisz }}, {{ sec_st.prisz | times: 1.5 | round }}, {{ sec_st.prisz | times: 2 }}{%- endcapture -%}
          {{- sec_st.prico | image_url: width: 100 | image_tag: class: 'at-icon mr10', widths:prico_width, height:sec_st.prisz, width:sec_st.prisz, alt:sec_st.prico.alt -}}
        {%- endif -%}
        <div style="color:{{ sec_st.prcl }}; font-size:{{ sec_st.prfs }}px; line-height:1.1;">
          {%- if sec_st.promo_head != blank -%}<p style="color:{{ sec_st.prtcl }}; font-size:{{ sec_st.prtfs }}px; font-weight:{{ sec_st.prfw }};margin-bottom:2px;">{{ sec_st.promo_head }}</p>{%- endif -%}
          {%- if sec_st.promo_text != blank -%}<span>{{ sec_st.promo_text }}</span>{%- endif -%}
        </div>
      </div>
      {%- endif -%}
{%- endcapture -%}

{%- capture nav_toggle -%}
    <a href="#" class="hdicon navToggle hide-lg{% if desktop_drawer_enabled %} lume-desktop-nav-toggle lume-desktop-nav-toggle--{{ desktop_hamburger_style }}{% endif %}" role="button" title="{{ 'sections.navigation.menu' | t }}" aria-haspopup="dialog" aria-controls="mobNav" aria-expanded="false"><svg class="at-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 464.205 464.205"><path d="m435.192 406.18h-406.179c-16.024 0-29.013-12.99-29.013-29.013s12.989-29.013 29.013-29.013h406.18c16.023 0 29.013 12.99 29.013 29.013-.001 16.023-12.99 29.013-29.014 29.013z"/><path d="m435.192 261.115h-406.179c-16.024 0-29.013-12.989-29.013-29.012s12.989-29.013 29.013-29.013h406.18c16.023 0 29.013 12.989 29.013 29.013s-12.99 29.012-29.014 29.012z"/><path d="m435.192 116.051h-406.179c-16.024 0-29.013-12.989-29.013-29.013s12.989-29.013 29.013-29.013h406.18c16.023 0 29.013 12.989 29.013 29.013s-12.99 29.013-29.014 29.013z"/></svg></a>
{%- endcapture -%}

{%- capture site_header -%}
<header id="header" class="main_hdr fl f-aic col-gap pr{% if sec_st.sw %} fw-sec{% else %} page-width{% endif %}{% if istrnsparent %} trnsprt{% endif %}" data-sticky="{{ sec_st.sticky_type }}" data-sticky-desktop="{{ sec_st.sticky_type }}" data-sticky-mobile="{{ sticky_mobile_type }}" data-section-id="header" style="{% if sec_st.trhead %}--thcl:{{ sec_st.thcl }};{% endif %}--gap:{{ sec_st.gap }}px;">
      {%- if sec_st.cntlogo -%}
        <div class="fl1 mbnavCol fl hide-lg cnt">
            {{ nav_toggle }}
            {% if settings.enable_search and sec_st.cntlogo %}
              <a class="hdicon searchIcn" href="{{ routes.search_url }}" title="{{ 'sections.header.search' | t }}"><svg class="at-icon"><use xlink:href="#icon-search"></use></svg></a>
            {% endif %}
        </div>
      {%- endif -%}
      <div class="fl1 leftcol fl f-aic gap hide-sm hide-md" style="--gap:15px;">
          {%- if desktop_drawer_enabled -%}{{ nav_toggle }}{%- endif -%}
          {%- if sec_st.leftcol == '1' -%}
                {{ promo }}
            {%- elsif sec_st.leftcol == '2' -%}
                {% if settings.mlcurrency or settings.mlLang %}{%- render 'currencyLang' -%}{% endif %}
            {%- elsif sec_st.leftcol == '3' -%}
                {%- render 'social-media' -%}
            {%- elsif sec_st.leftcol == '4' -%}
              <div class="searchinline hide-sm hide-md">{%- render 'search-form', frmClas: 'hdSearch' -%}</div>
            {%- endif -%}
      </div>

      {{- logo -}}

      <div class="fl f-jce icons-col fl1">
        {%- if settings.enable_search -%}
		  <a class="hdicon searchIcn{% if sec_st.cntlogo %} hide-sm hide-md{% endif %}{% if sec_st.leftcol == '4' %} hide-lg{% endif %}" href="{{ routes.search_url }}" title="{{ 'sections.header.search' | t }}">
              <svg class="at-icon{% if sec_st.icntyp == '3' %} hide-lg{% endif %}"><use xlink:href="#icon-search"></use></svg>
              <p class="m0{% if sec_st.icntyp == '1' %} hide{% else %} hide-sm hide-md{% endif %}{% if sec_st.icntyp == '2' %} pdt5{% endif %}">{{ 'sections.header.search' | t }}</p>
          </a>
        {%- endif -%}
        {%- if shop.customer_accounts_enabled -%}
          {%- capture account_label_class -%}m0{% if sec_st.icntyp == '1' %} hide{% else %} hide-sm hide-md{% endif %}{% if sec_st.icntyp == '2' %} pdt5{% endif %}{%- endcapture -%}
          {%- render 'sls-account-component', wrapper_class: 'hdicon user-menu', icntyp: sec_st.icntyp, label_class: account_label_class -%}
        {%- endif -%}

        {%- if settings.wishlist -%}
          <a class="hdicon" href="{{ pages[settings.wishlist_page].url }}" title="{{ 'sections.header.wishlist' | t }}">
              <svg class="at-icon{% if sec_st.icntyp == '3' %} hide-lg{% endif %}"><use xlink:href="#icon-wishlist"></use></svg>
              {%- if sec_st.icntyp != '3' -%}<b id="wishlistItems" class="cartCount pp">0</b>{%- endif -%}
              <p class="m0{% if sec_st.icntyp == '1' %} hide{% else %} hide-sm hide-md{% endif %}{% if sec_st.icntyp == '2' %} pdt5{% endif %}">{{ 'sections.header.wishlist' | t }}</p>
          </a>
        {%- endif -%}

        {%- unless settings.catalog-mode -%}
		<a href="#cart-drawer" class="hdicon" id="cartLink" title="{{ 'sections.header.cart' | t }}" role="button" aria-haspopup="dialog" aria-controls="CartDrawer" data-sls-cart-trigger data-sls-cart-href="{{ routes.cart_url }}" onclick="return window.SLSOpenCartFromLink ? window.SLSOpenCartFromLink(event, this) : false;">
            <svg class="at-icon{% if sec_st.icntyp == '3' %} hide-lg{% endif %}"><use xlink:href="#icon-cart"></use></svg>
            {%- if sec_st.icntyp != '3' -%}<b id="cart-icon-bubble" class="cartCount pp">{{ cart.item_count }}</b>{%- endif -%}
            <p class="m0{% if sec_st.icntyp == '1' %} hide{% else %} hide-sm hide-md{% endif %}{% if sec_st.icntyp == '2' %} pdt5{% endif %}">{{ 'sections.header.cart' | t }}{% if sec_st.icntyp == '3' %}<b id="cart-icon-bubble" class="cartCount pp">{{ cart.item_count }}</b>{% endif %}</p>
        </a>
        {%- endunless -%}
        {%- unless sec_st.cntlogo -%}
            <a href="#" class="hdicon navToggle hide-lg" title="{{ 'sections.navigation.menu' | t }}"><svg class="at-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 464.205 464.205"><path d="m435.192 406.18h-406.179c-16.024 0-29.013-12.99-29.013-29.013s12.989-29.013 29.013-29.013h406.18c16.023 0 29.013 12.99 29.013 29.013-.001 16.023-12.99 29.013-29.014 29.013z"/><path d="m435.192 261.115h-406.179c-16.024 0-29.013-12.989-29.013-29.012s12.989-29.013 29.013-29.013h406.18c16.023 0 29.013 12.989 29.013 29.013s-12.99 29.012-29.014 29.012z"/><path d="m435.192 116.051h-406.179c-16.024 0-29.013-12.989-29.013-29.013s12.989-29.013 29.013-29.013h406.18c16.023 0 29.013 12.989 29.013 29.013s-12.99 29.013-29.014 29.013z"/></svg></a>
        {%- endunless -%}
      </div>
</header>
    {%- unless desktop_drawer_enabled -%}
    <nav id="main_navwr" class="{% if istrnsparent %}trnsprt {% endif %}hide-sm hide-md" role="navigation">
        <div class="{% if sec_st.sw %} fw-sec{% else %} page-width{% endif %}">
            {%- render 'navigation', sec_st:sec_st, secblk:section.blocks, cnt_width:cnt_width -%}
        </div>
    </nav>
    {%- endunless -%}
    {%-liquid
        if settings.enable_search
            assign search_type = 'drawer'
            if sec_st.leftcol == '4'
                assign search_type = 'inline'
            endif
            render 'search-drawer', search_type:search_type, cnt_width:cnt_width, is_rtl:is_rtl
          endif
    -%}
<!--mmobile-->
{%- render 'mobile-nav', sec_st:sec_st, secblk:section.blocks, desktop_drawer_enabled:desktop_drawer_enabled, desktop_drawer_position:desktop_drawer_position, desktop_drawer_width:desktop_drawer_width, desktop_category_menu:sec_st.desktop_catmenu -%}
{%- endcapture -%}
{{- site_header | replace:"<!--mmobile-->", "</div>" | strip_newlines | remove: "  " | remove: "	" -}}
{% schema %}
 {
    "name": "Header - Menu Bottom",
	"limit": 1,
    "class": "hdr_wrap pr hdr_bottom",
    "enabled_on": {
        "groups": ["header"]
    },
    "settings": [
      {
        "type": "range",
        "id": "ht",
        "min": 50,
        "max": 150,
        "step": 1,
        "label": "Header Height",
        "default": 70
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo Image"
      },
      {
        "type": "range",
        "id": "logowd",
        "min": 50,
        "max": 500,
        "step": 5,
        "label": "Logo Width",
        "default": 120
      },
      {
        "type": "select",
        "id": "icntyp",
        "label": "Addons",
        "default": "2",
        "options": [
          {
            "label": "Icons only",
            "value": "1"
          },
          {
          "label": "Icon with text",
            "value": "2"
          },
          {
          "label": "Text only",
            "value": "3"
          }
        ]
      },
      {
        "type": "range",
        "id": "icon",
        "min": 12,
        "max": 50,
        "step": 1,
        "label": "Icons Size",
        "unit": "px",
        "default": 18
      },
      {
        "type": "range",
        "id": "fs",
        "min": 10,
        "max": 20,
        "step": 1,
        "label": "Font Size",
        "unit": "px",
        "default": 12
      },
      {
        "type": "color",
        "id": "cl",
        "label": "Icons & Text",
        "default": "#222222"
      },
      {
        "type": "color",
        "id": "clh",
        "label": "Icons & Text Hover",
        "default": "#222222"
      },
      {
            "type": "select",
            "id": "leftcol",
            "label": "Left Column",
            "default": "2",
            "info":"Enable Currency & Language from Theme Settings",
            "options": [
              {
                "label": "Promotional Text",
                "value": "1"
              },
              {
              "label": "Currency & Language",
                "value": "2"
              },
              {
              "label": "Social Icons",
                "value": "3"
              },
              {
              "label": "Search Box",
                "value": "4"
              }
            ]
      },
	  {
        "type": "header",
        "content": "Promotional Text ====",
        "visible_if": "{{ section.settings.leftcol == '1' }}"
      },
      {
          "type": "image_picker",
          "id": "prico",
          "label": "Image or Svg Icon",
          "info":"[Available SVG icons.](https://adornthemes.com/documentation/vogal/svg-icons.html)",
           "visible_if": "{{ section.settings.leftcol == '1' }}"
      },
      {
        "type": "range",
        "id": "prisz",
        "label": "Icon Size",
        "default": 30,
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "visible_if": "{{ section.settings.leftcol == '1' }}"
      },
      {
        "type": "text",
        "id": "promo_head",
        "label": "Heading",
        "default": "Expert Support",
        "visible_if": "{{ section.settings.leftcol == '1' }}"
      },
      {
        "type": "color",
        "id": "prtcl",
        "label": "Color",
        "default": "#222222",
        "visible_if": "{{ section.settings.leftcol == '1' }}"
      },
      {
        "type": "range",
        "id": "prtfs",
        "label": "Font Size",
        "default": 16,
        "min": 10,
        "max": 60,
        "step": 1,
        "unit": "px",
         "visible_if": "{{ section.settings.leftcol == '1' }}"
      },
      {
        "type": "select",
        "id": "prfw",
        "label": "Font Weight",
        "default": "500",
        "visible_if": "{{ section.settings.leftcol == '1' }}",
        "options": [
          {
            "value": "300",
            "label": "Light"
          },
          {
            "value": "400",
            "label": "Regular"
          },
          {
            "value": "500",
            "label": "Medium"
          },
          {
            "value": "600",
            "label": "Semi Bold"
          },
          {
            "value": "700",
            "label": "Bold"
          }
        ]
      },
      {
        "type": "text",
        "id": "promo_text",
        "label": "Promo. Text",
        "default": "Available 24\/7 via chat",
        "visible_if": "{{ section.settings.leftcol == '1' }}"
      },
	  {
        "type": "color",
        "id": "prcl",
        "label": "Color",
        "default": "#222222",
        "visible_if": "{{ section.settings.leftcol == '1' }}"
      },
      {
        "type": "range",
        "id": "prfs",
        "label": "Font Size",
        "default": 12,
        "min": 10,
        "max": 30,
        "step": 1,
        "unit": "px",
        "visible_if": "{{ section.settings.leftcol == '1' }}"
      },
      {
        "type": "header",
        "content": "Sticky Header ====="
      },
      {
        "type": "select",
        "id": "sticky_type",
        "label": "Desktop sticky header",
        "default": "top",
        "options": [
          {
            "value": "none",
            "label": "None"
          },
          {
            "value": "always",
            "label": "Always"
          },
          {
            "value": "top",
            "label": "On scroll up"
          }
        ]
      },
      {
        "type": "select",
        "id": "sticky_type_mobile",
        "label": "Mobile sticky header",
        "default": "inherit",
        "options": [
          {
            "value": "inherit",
            "label": "Same as desktop"
          },
          {
            "value": "none",
            "label": "None"
          },
          {
            "value": "always",
            "label": "Always"
          },
          {
            "value": "top",
