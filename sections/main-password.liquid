{%- assign section_st = section.settings -%}

<div class="lume-password-page">
  <div class="clr-header">
    <div class="password-header">
      <div class="password-header__left">
        {% if section_st.logo %}
          <a href="{{ routes.root_url }}" itemprop="url" class="m0 password-logo-link">
            {%- assign logo_alt = section_st.logo.alt | default: shop.name | escape -%}
            {% capture sizes %}(max-width: {{ section_st.logowd | times: 2 }}px) 50vw, {{ section_st.logowd }}px{% endcapture %}
            {% capture widths %}{{ section_st.logowd }}, {{ section_st.logowd | times: 1.5 | round }}, {{ section_st.logowd | times: 2 }}{% endcapture %}
            {%- assign logo_ht = section_st.logowd | divided_by: section_st.logo.aspect_ratio -%}
            {{ section_st.logo | image_url: width: 600 | image_tag: class: 'stlogo', widths: widths, height: logo_ht, width: section_st.logowd, alt: logo_alt, sizes: sizes, preload: true }}
          </a>
        {% else %}
          <h1 class="m0" itemprop="url"><span class="logo">{{ shop.name }}</span></h1>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="password-main h_100 fl f-jcc f-aic" role="main">
    <div class="passCnt tc">
      <div class="lume-pass-card">

        <div class="lume-pass-eyebrow">AMBASSADOR ACCESS</div>

        <h2 class="password__title">{{ section_st.header }}</h2>

        {% if shop.password_message != blank %}
          <div class="password-content tc lume-password-message">
            {{ shop.password_message }}
          </div>
        {% endif %}

        {% if section_st.newsletter_form_heading != blank %}
          <p class="nwTxt">{{ section_st.newsletter_form_heading }}</p>
        {% endif %}

        {% if section_st.hero_dealtimer %}
          <div
            class="atCounter lume-counter tc ht{{ section.id }}"
            data-datetime="{{ section_st.cnt_datetime | escape }}"
          >
            <span>
              <span class="tm days">00</span>
              <span class="lbl">{{ 'date_formats.days' | t }}</span>
            </span>
            <span>
              <span class="tm hours">00</span>
              <span class="lbl">{{ 'date_formats.hours' | t }}</span>
            </span>
            <span>
              <span class="tm minutes">00</span>
              <span class="lbl">{{ 'date_formats.minuts' | t }}</span>
            </span>
            <span>
              <span class="tm seconds">00</span>
              <span class="lbl">{{ 'date_formats.seconds' | t }}</span>
            </span>
          </div>
        {% endif %}

        <div class="lume-password-cta">
          <a href="#LoginModal" class="js-modal-open-login-modal lume-password-btn">
            Enter Password
          </a>
        </div>

        {% if section_st.newsletter_enable %}
          {% form 'customer' %}
            {{ form.errors | default_errors }}

            {% if form.posted_successfully? %}
              <p class="form-success">{{ 'general.password_page.signup_form_success' | t }}</p>
            {% else %}
              <input type="hidden" name="contact[tags]" value="prospect, password page">
              <label for="Email" class="hidden_txt">{{ 'general.password_page.signup_form_email_label' | t }}</label>

              <div class="ad_inputs fl password_input lume-newsletter-row">
                <input
                  class="fl1"
                  type="email"
                  name="contact[email]"
                  id="Email"
                  placeholder="{{ section_st.newsletter_placeholder | escape }}"
                >
                <button type="submit" name="commit" class="btn lume-newsletter-btn">
                  {{ section_st.newsletter_button_text | escape }}
                </button>
              </div>
            {% endif %}
          {% endform %}
        {% endif %}

        <div class="lume-password-note">
          Reserved for Studio Lume ambassadors prior to public launch.
        </div>

      </div>
    </div>
  </div>

  <div class="clr-footer">
    <div class="password-footer tc">
      {% if section_st.show_share_buttons %}
        <p class="mb10">{{ section_st.social_message | escape }}</p>
        <div class="mb20">{% render 'social-sharing' %}</div>
      {% endif %}

      <div class="admin-login">
        {% if section_st.show_powered_by %}
          {% capture shopify %}<a class="tdu shopify-link" href="//www.shopify.com" rel="nofollow" target="_blank" title="Create your own online store with Shopify">Shopify</a>{% endcapture %}
          <p class="mb5"><small>{{ 'general.password_page.powered_by_shopify_html' | t: shopify: shopify }}</small></p>
        {% endif %}
        <small>{{ 'general.password_page.admin_link_html' | t }}</small>
      </div>
    </div>
  </div>
</div>

<style type="text/css">
  {% if section_st.image != blank %}
    body,
    #LoginModal {
      background: url('{{ section_st.image | image_url: width: 2000 }}') no-repeat center {{ section_st.alignment }}/cover {{ section_st.bgclr }};
    }
  {% else %}
    body,
    #LoginModal {
      background-color: {{ section_st.bgclr }};
    }
  {% endif %}

  .lume-password-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .clr-header {
    color: {{ section_st.header-text }};
    background-color: rgba({{ section_st.header-bg | color_to_rgb | remove:'rgb(' | remove: ')' }}, {{ section_st.hdbg_opt }});
    border-bottom: 1px solid rgba(134,126,115,0.08);
  }

  .password-header {
    padding: 14px 20px;
    min-height: {{ section_st.header_h }}px;
    display: flex;
    justify-content: center;
    max-width: 1200px;
    align-items: center;
    margin: 0 auto;
    gap: 18px;
  }

  .password-header__left {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .password-logo-link {
    line-height: 0;
  }

  .password-main {
    flex: 1 1 auto;
  }

  .passCnt {
    position: relative;
    z-index: 2;
    padding: 64px 12px;
    max-width: 760px;
    margin: auto;
    width: 100%;
  }

  .lume-pass-card {
    max-width: 620px;
    margin: 0 auto;
    padding: 42px 34px 32px;
    text-align: center;
    border: 1px solid rgba(134,126,115,0.12);
    border-radius: 24px;
    background: rgba(255,255,255,0.92);
    box-shadow: 0 10px 30px rgba(89,89,89,0.04);
  }

  .lume-pass-eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    padding: 7px 16px;
    min-width: 210px;
    border-radius: 999px;
    border: 1px solid rgba(134,126,115,0.12);
    color: #867e73;
    font-size: 9px;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .password__title {
    color: {{ section_st.header-ft }};
    font-size: 18px;
    font-family: var(--{{ section_st.hd2_fs_font }});
    font-weight: 400;
    line-height: 1.45;
    margin: 0 auto 22px;
    max-width: 420px;
  }

  .lume-password-message {
    max-width: 420px;
    margin: 0 auto 14px;
    color: #867e73;
    font-size: 12px;
    line-height: 1.65;
  }

  .nwTxt {
    color: {{ section_st.header-nwft }};
    max-width: 420px;
    margin: 0 auto 22px;
    font-size: 13px;
    line-height: 1.7;
    font-weight: 300;
  }

  .lume-counter.atCounter {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    max-width: 430px;
    margin: 0 auto 26px;
  }

  .lume-counter.atCounter > span {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 8px;
    min-height: 96px;
    padding: 16px 8px;
    border-radius: {{ section_st.b_rad }}px;
    text-transform: none;
    font-weight: 400;
    line-height: 1.2;
    color: {{ section_st.cnt_text }};
    background: {{ section_st.cnt_bg }};
    border: 1px solid {{ section_st.cnt_bdr }};
  }

  .lume-counter .tm {
    display: block;
    font-size: 24px;
    line-height: 1;
    font-weight: 400;
  }

  .lume-counter .lbl {
    display: block;
    font-size: 10px;
    line-height: 1.2;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.9;
  }

  .lume-password-cta {
    margin: 6px 0 0;
    display: flex;
    justify-content: center;
  }

  .lume-password-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 26px;
    border-radius: 999px;
    background: #867e73;
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 10px;
    font-weight: 500;
    transition: .2s ease;
  }

  .lume-password-btn:hover {
    background: #746c62;
    color: #ffffff;
  }

  .lume-newsletter-row {
    max-width: 420px;
    margin: 22px auto 0;
    gap: 8px;
  }

  .lume-newsletter-row input {
    height: 44px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1px solid rgba(134,126,115,0.16);
    background: #ffffff;
    color: #222222;
  }

  .lume-newsletter-row input::placeholder {
    color: #aca39a;
  }

  .lume-newsletter-btn {
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: #222222;
    color: #ffffff;
    border: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 10px;
    font-weight: 500;
  }

  .lume-password-note {
    margin-top: 18px;
    color: #867e73;
    font-size: 10px;
    line-height: 1.55;
  }

  .password-footer {
    max-width: 1200px;
    margin: 0 auto;
    min-height: 80px;
    display: flex;
    flex-direction: column;
  }

  .admin-login a {
    color: {{ section_st.footer-text }};
  }

  .password-footer .share-title {
    display: none;
  }

  .clr-footer {
    color: {{ section_st.footer-text }};
    padding: 20px 15px;
    background: rgba({{ section_st.footer-bg | color_to_rgb | remove:'rgb(' | remove: ')' }}, {{ section_st.ftbg_opt }});
    border-top: 1px solid rgba(134,126,115,0.08);
  }

  .passCnt .errors {
    max-width: 320px;
    margin: 0 auto 14px;
    font-size: 12px;
  }

  @media only screen and (max-width: 766px) {
    .password-header {
      justify-content: center;
      padding: 16px 15px;
      text-align: center;
    }

    .lume-pass-card {
      padding: 30px 18px 24px;
      border-radius: 22px;
    }

    .lume-pass-eyebrow {
      min-width: 0;
      width: 100%;
      max-width: 240px;
      font-size: 8px;
      margin-bottom: 14px;
    }

    .password__title {
      font-size: 16px;
      margin-bottom: 10px;
      max-width: 240px;
    }

    .nwTxt,
    .lume-password-message {
      font-size: 12px;
      max-width: 250px;
      margin-left: auto;
      margin-right: auto;
    }

    .lume-counter.atCounter {
      grid-template-columns: repeat(2, 1fr);
      max-width: 260px;
      gap: 12px;
    }

    .lume-counter.atCounter > span {
      min-height: 88px;
      padding: 12px 8px;
    }

    .lume-counter .tm {
      font-size: 22px;
    }

    .lume-counter .lbl {
      font-size: 9px;
    }

    .lume-password-cta {
      margin-top: 16px;
    }

    .lume-password-btn {
      width: 100%;
      max-width: 250px;
    }

    .lume-newsletter-row {
      flex-direction: column;
      max-width: 250px;
    }

    .lume-newsletter-row input,
    .lume-newsletter-btn {
      width: 100%;
    }

    .lume-password-note {
      max-width: 250px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var counters = document.querySelectorAll('.lume-counter');

  counters.forEach(function(counter) {
    var datetimeStr = counter.getAttribute('data-datetime');
    if (!datetimeStr) return;

    var normalised = datetimeStr.trim().replace(' ', 'T');
    var target = new Date(normalised).getTime();

    if (isNaN(target)) return;

    var daysEl = counter.querySelector('.days');
    var hoursEl = counter.querySelector('.hours');
    var minutesEl = counter.querySelector('.minutes');
    var secondsEl = counter.querySelector('.seconds');

    function pad(num) {
      return String(num).padStart(2, '0');
    }

    function updateCounter() {
      var now = new Date().getTime();
      var diff = target - now;

      if (diff <= 0) {
        if (daysEl) daysEl.textContent = '00';
        if (hoursEl) hoursEl.textContent = '00';
        if (minutesEl) minutesEl.textContent = '00';
        if (secondsEl) secondsEl.textContent = '00';
        return;
      }

      var days = Math.floor(diff / (1000 * 60 * 60 * 24));
      var hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      var minutes = Math.floor((diff / (1000 * 60)) % 60);
      var seconds = Math.floor((diff / 1000) % 60);

      if (daysEl) daysEl.textContent = pad(days);
      if (hoursEl) hoursEl.textContent = pad(hours);
      if (minutesEl) minutesEl.textContent = pad(minutes);
      if (secondsEl) secondsEl.textContent = pad(seconds);
    }

    updateCounter();
    setInterval(updateCounter, 1000);
  });
});
</script>

