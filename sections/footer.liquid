{%- capture footer -%}
{%- assign section_st = section.settings -%}
{%- assign show_footer_localization = false -%}
{%- if section_st.show_localization -%}
  {%- if settings.mlcurrency or settings.mlLang -%}
    {%- assign show_footer_localization = true -%}
  {%- endif -%}
{%- endif -%}
{%- capture ftstyle -%}
    --cl:{{ section_st.cl }};--clh:{{ section_st.clh }};--fs:{{ section_st.fs }}px;--fsm:{{ section_st.fsm }}px;
    --tcl:{{ section_st.tcl }};--ff:var(--{{ section_st.ff }});--tfs:{{ section_st.tfs }}px;--tfsm:{{ section_st.tfsm }}px;
    --icn:{{ section_st.icn }};--icns:{{ section_st.ifs }}px;--bg:{% if section_st.bgg != blank %}{{ section_st.bgg }}{% else %}{{ section_st.bg }}{% endif %};--bdr:{{ section_st.bdr }};--bdrm:{{ section_st.bdrm }};--tfw:{{ section_st.tfw }};--sls-footer-legal-bg:{{ section_st.footer_legal_bg | default: '#fbf1f5' }};--sls-footer-ptm:{{ section_st.footer_padding_top_mobile | default: 58 }}px;--sls-footer-pbm:{{ section_st.footer_padding_bottom_mobile | default: 0 }}px;--sls-footer-ptd:{{ section_st.footer_padding_top_desktop | default: 72 }}px;--sls-footer-pbd:{{ section_st.footer_padding_bottom_desktop | default: 0 }}px;
    {% if section_st.bgimg != blank %}background-repeat:{{ section_st.bgrep }}; background-size:{{ section_st.bgsz }}; background-position:{{ section_st.bgpos | replace:"_", " " }}; background-attachment:{{ section_st.bgat }}; {% endif %}
{%- endcapture -%}
{%- assign footer_logo_width = section_st.footer_logo_width | default: 150 -%}
{%- assign footer_logo_width_mobile = section_st.footer_logo_width_mobile | default: 132 -%}

{%- capture sls_footer_logo -%}
  {%- if section_st.footer_logo != blank -%}
    {%- assign footer_logo_alt = section_st.footer_logo.alt | default: shop.name | escape -%}
    {%- capture footer_logo_widths -%}{{ footer_logo_width }}, {{ footer_logo_width | times: 1.5 | round }}, {{ footer_logo_width | times: 2 }}{%- endcapture -%}
    <a class="sls-luxe-footer__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {{ section_st.footer_logo | image_url: width: 500 | image_tag: loading:'lazy', class:'sls-luxe-footer__logo-image', widths: footer_logo_widths, width: footer_logo_width, alt: footer_logo_alt }}
    </a>
  {%- endif -%}
{%- endcapture -%}

{%- capture sls_footer_socials -%}
  <div class="sls-luxe-footer__socials">
    {% render 'social-media' %}
  </div>
{%- endcapture -%}

{%- capture sls_footer_brand -%}
  {{ sls_footer_logo }}
  {{ sls_footer_socials }}
{%- endcapture -%}

{%- capture sls_footer_payments -%}
  {%- if section_st.show_payment -%}
    <div class="sls-luxe-footer__payments" aria-label="Payment methods">
      {%- if section_st.payimg != blank -%}
        <img src="{{ section_st.payimg | image_url: width: 600 }}" alt="" width="" height="" style="max-width:{{ section_st.payimgwd }}px" loading="lazy" />
      {%- else -%}
        {% for type in shop.enabled_payment_types %}{{ type | payment_type_svg_tag: class: 'payment_item' }}{% endfor %}
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endcapture -%}

<footer class="at_footer sls-luxe-footer{% if section_st.bgimg != blank %} lazyload{% endif %} {% render 'animate-data', css:true, text:true %}" {% render 'animate-data' %} role="contentinfo" style="{{ ftstyle }};--sls-footer-logo-width:{{ footer_logo_width }}px;--sls-footer-logo-width-mobile:{{ footer_logo_width_mobile }}px;"
    {% if section_st.bgimg != blank %}data-bgset="{{ section_st.bgimg | image_url: width: section_st.bgimg.width | image_tag: widths: '400,600,800,1000,1400,1600,2000,2400,3000' | split: 'srcset="' | last | split: '"' | first }}" data-sizes="auto" data-parent-fit="contain"{% endif %}>
    <div class="{% if section_st.sw %}fw-sec{% else %}page-width{% endif %} sls-luxe-footer__main">
      <div class="sls-luxe-footer__brand sls-luxe-footer__brand--mobile">
        {{ sls_footer_brand }}
      </div>

      <div class="sls-luxe-footer__desktop">
        <div class="sls-luxe-footer__menus">
          {%- for block in section.blocks -%}
            {%- assign block_st = block.settings -%}
            {%- if block.type == 'menu' or block.type == 'hmenu' -%}
              {%- unless block_st.hide_desk -%}
                <nav class="sls-luxe-footer__menu {{ block_st.width }}" aria-label="{{ block_st.title | default: 'Footer menu' | escape }}" {{ block.shopify_attributes }}>
                  {%- if block_st.title != blank -%}<p class="sls-luxe-footer__heading">{{ block_st.title }}</p>{%- endif -%}
                  <ul>
                    {%- for link in linklists[block_st.menu].links -%}
                      <li><a href="{{ link.url }}" {% if link.title contains '[new]' %}target="_blank"{% endif %}>{{ link.title | split: '[' | first }}</a></li>
                    {%- endfor -%}
                  </ul>
                </nav>
              {%- endunless -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="sls-luxe-footer__desktop-lower">
          {%- if section_st.footer_logo != blank -%}
            <div class="sls-luxe-footer__brand sls-luxe-footer__brand--desktop">
              {{ sls_footer_logo }}
            </div>
          {%- endif -%}
          <div class="sls-luxe-footer__desktop-bottom-row" style="display:grid;grid-template-columns:minmax(110px,1fr) auto minmax(300px,1fr);align-items:center;column-gap:18px;width:100%;max-width:1040px;margin:0 auto;">
            <div class="sls-luxe-footer__desktop-bottom-cell sls-luxe-footer__desktop-bottom-cell--socials">
              {{ sls_footer_socials }}
            </div>
            <div class="sls-luxe-footer__desktop-bottom-cell sls-luxe-footer__desktop-bottom-cell--localization">
              {% if show_footer_localization %}
                <div class="ft-localization sls-luxe-footer__localization" aria-label="{{ 'sections.navigation.language' | t }} and {{ 'sections.navigation.currency' | t }}">
                {% render 'currencyLang', form_id_suffix: '-FooterDesktop' %}
                </div>
              {% endif %}
            </div>
            <div class="sls-luxe-footer__desktop-bottom-cell sls-luxe-footer__desktop-bottom-cell--payments">
              {{ sls_footer_payments }}
            </div>
              </div>
        </div>
      </div>

      <div class="sls-luxe-footer__accordions">
        {%- for block in section.blocks -%}
          {%- assign block_st = block.settings -%}
          {%- if block.type == 'menu' or block.type == 'hmenu' -%}
            {%- unless block_st.hidem -%}
              <div class="sls-luxe-footer__accordion" {{ block.shopify_attributes }}>
                <button type="button" class="sls-luxe-footer__accordion-title" data-sls-footer-accordion-toggle aria-expanded="false" aria-controls="sls-footer-accordion-{{ block.id }}">
                  <span>{{ block_st.title }}</span>
                  <span class="sls-luxe-footer__accordion-icon" aria-hidden="true"></span>
                </button>
                <div class="sls-luxe-footer__accordion-panel" id="sls-footer-accordion-{{ block.id }}">
                  <div class="sls-luxe-footer__accordion-panel-inner">
                    <ul class="sls-luxe-footer__accordion-links">
                      {%- for link in linklists[block_st.menu].links -%}
                        <li><a href="{{ link.url }}" {% if link.title contains '[new]' %}target="_blank"{% endif %}>{{ link.title | split: '[' | first }}</a></li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </div>
              </div>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="sls-luxe-footer__market-payments sls-luxe-footer__market-payments--mobile">
        {% if show_footer_localization %}
          <div class="ft-localization sls-luxe-footer__localization" aria-label="{{ 'sections.navigation.language' | t }} and {{ 'sections.navigation.currency' | t }}">
            {% render 'currencyLang', form_id_suffix: '-FooterMobile' %}
          </div>
        {% endif %}
        {{ sls_footer_payments }}
      </div>
    </div>

    <div class="sls-luxe-footer__legal" style="--sls-footer-legal-bg:{{ section_st.footer_legal_bg | default: '#afafafff' }}; background-color:{{ section_st.footer_legal_bg | default: '#afafafff' }};">
      <div class="{% if section_st.sw %}fw-sec{% else %}page-width{% endif %} sls-luxe-footer__legal-inner">
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <span aria-hidden="true">|</span>
        <a href="/policies/terms-of-service">Terms of Service</a>
        {% if section_st.copyright_text != blank %}
          <span aria-hidden="true">|</span>
          <span>{% assign year = "now" | date: "%Y" %}{% assign insert_year = year %}{{ section_st.copyright_text | replace:"[year]", insert_year }}</span>
        {% endif %}
      </div>
    </div>
</footer>
<script>
  (function(){
    if(window.SLSFooterAccordionReady) return;
    window.SLSFooterAccordionReady = true;

    function markFooterLink(link){
      if(!link) return;
      link.classList.add('is-clicked');
      window.clearTimeout(link.slsFooterClickTimer);
      link.slsFooterClickTimer = window.setTimeout(function(){
        link.classList.remove('is-clicked');
      }, 900);
    }

    document.addEventListener('pointerdown', function(event){
      var link = event.target.closest('.sls-luxe-footer__accordion-links a, .sls-luxe-footer__legal a');
      if(!link || !link.closest('.sls-luxe-footer')) return;
      markFooterLink(link);
    }, { passive: true });

    document.addEventListener('click', function(event){
      var link = event.target.closest('.sls-luxe-footer__accordion-links a, .sls-luxe-footer__legal a');
      if(!link || !link.closest('.sls-luxe-footer')) return;
      markFooterLink(link);
    });

    document.addEventListener('click', function(event){
      var button = event.target.closest('[data-sls-footer-accordion-toggle]');
      if(!button || !button.closest('.sls-luxe-footer')) return;

      var panel = document.getElementById(button.getAttribute('aria-controls')) || button.nextElementSibling;
      if(!panel || !panel.classList.contains('sls-luxe-footer__accordion-panel')) return;

      event.preventDefault();
      event.stopPropagation();

      var isOpen = panel.classList.contains('active');
      button.classList.toggle('active', !isOpen);
      button.setAttribute('aria-expanded', String(!isOpen));
      panel.classList.toggle('active', !isOpen);
    });
  })();
</script>
{%- endcapture -%}
