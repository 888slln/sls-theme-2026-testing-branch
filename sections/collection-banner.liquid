 {% assign section_st = section.settings %}
{%- capture top_banner -%}
    <div class="sec_cov npd"  style="--sbg:{% if section_st.bgg != blank %}{{ section_st.bgg }}{% else %}{{ section_st.bg }}{% endif %};">
            {%- liquid
                assign banner_img = section_st.image
                assign banner_imgm = section_st.mb_image
                assign banner_imgm_srcset = banner_imgm | image_url: width: banner_imgm.width | image_tag: widths: '360,480,760' | split: 'srcset="' | last | split: '"' | first
            -%}
            {% if section_st.image != blank %}
            <picture class="overlay" style="--overlay:{{ section_st.overlay | color_modify: 'alpha', section_st.overlay_op }};">
                {% if section_st.mb_image != blank %}
                    <source media="(max-width: 767px)" srcset="{{ banner_imgm_srcset }}" width="{{ banner_imgm.width }}" height="{{ banner_imgm.height }}">
                {% endif %}
                {{ banner_img | image_url: width: banner_img.width | image_tag: class:'imgFt heroImg', width:banner_img.width, height:banner_img.height, widths:"400,600,800,1000,1200,1400,1600,2000,2400,3000" }}
            </picture>
            {% endif %}
            {%  if  section.blocks.size > 0 %}
                <div class="hero_wrap fl{% if section_st.text-align %} f-jcc tc{% endif %} f-aic m_auto" style="--mht:{{ section_st.hit }}px;--mhtt:{{ section_st.hitt }}px;--mhtm:{{ section_st.hitm }}px;--mwd:{{ section_st.cntwd }}px;">
                    <div class="pr zi1 {% render 'animate-data', css:true %}">
                        {% for block in section.blocks %}
                            {% assign block_st = block.settings %}
                            {% if block.type == 'title' %}
                                <{{ block_st.htag}} class="rgTxt {{ block_st.tff}} mb{{block_st.mbm}} mb{{ block_st.mb }}-md{% if block_st.tuu %} ttu{% endif %}" style="--cl:{{ block_st.cl }};--fs:{{ block_st.fs }}px;--fsm:{{ block_st.fsm }}px;--fw:{{ block_st.fw }};--lh:{{ block_st.lh }};" {{ block.shopify_attributes }}>{{ collection.title }}</{{  block_st.htag }}>
                            {% elsif block.type == 'countdown' %}
                                <countdown-time class="atCounter box_timer fl{% if section_st.text-align %} f-jcc{% endif %} tc mb{{ block_st.mbm }} mb{{ block_st.mb }}-md ttu" data-date="{{ block_st.date }}"
                                     style="--cl:{{ block_st.cl }};--bg:{{ block_st.bg }};--bd:{{ block_st.bdr }};--rounded:{{ block_st.radius }}px;--fs:{{ block_st.fs }}px;--fsl:{{ block_st.fsl }}px;" {{ block.shopify_attributes }}>
                                    <span class="pd10"><span class="tm days">00</span>{{ 'date_formats.days' | t }}</span>
                                    <span class="pd10"><span class="tm hours">00</span>{{ 'date_formats.hours' | t }}</span>
                                    <span class="pd10"><span class="tm minutes">00</span>{{ 'date_formats.minuts' | t }}</span>
                                    <span class="pd10"><span class="tm seconds">00</span>{{ 'date_formats.seconds' | t }}</span>
                                </countdown-time>
                            {% elsif block.type == 'bc' %}
                                <nav class="breadcrumb inline fl f-wrap f-aic f-jcc{% if block_st.hidemb %} hide-sm{% endif %}{% if settings.bcase %} ttu{% endif %}" role="navigation" aria-label="breadcrumbs" style="--cl:{{ block_st.cl }};--fs:{{ block_st.fs }}px;--fsm:{{ block_st.fsm }}px">
                                    <a href="{{ routes.root_url }}" title="{{ 'general.breadcrumbs.home_link_title' | t }}">{{ 'general.breadcrumbs.home' | t }}</a>
                                    <span class="barr" aria-hidden="true"><svg class="at-icon arw right"><use xlink:href="#icon-arrow"></use></svg></span>
                                    {% if current_tags %}
                                        {% capture url %}{{ routes.collections_url }}/{{ collection.handle }}{% endcapture %}
                                        {{ collection.title | link_to: url }}
                                        <span class="barr" aria-hidden="true"><svg class="at-icon arw right"><use xlink:href="#icon-arrow"></use></svg></span>
                                        <span>{{ current_tags | join: " + " }}</span>
                                    {% else %}
                                        <span class="fwm">{{ collection.title }}</span>
                                    {% endif %}
                                </nav>
                                <script type="application/ld+json">
                                  {
                                      "@context": "https://schema.org",
                                      "@type": "BreadcrumbList",
                                      "itemListElement": [
                                          {
                                              "@type": "ListItem",
                                              "position": 1,
                                              "item": {
                                                  "@id": "{{ routes.root_url }}",
                                                  "name": "{{ 'general.breadcrumbs.home' | t }}"
                                              }
                                          }
                                              ,{
                                                  "@type": "ListItem",
                                                  "position": 2,
                                                  "item": {
                                                      "@id": "{{ routes.collections_url }}/{{ collection.handle }}",
                                                      "name": "{{ collection.title }}"
                                                  }
                                              }
                                      ]
                                  }
                                  </script>
                            {% elsif block.type == 'text' %}
                                <div class="rgTxt mb{{ block_st.mbm }} mb{{ block_st.mb }}-md{% if block_st.hidemb %} hide-sm{% endif %}" style="--cl:{{ block_st.cl }};--fs:{{ block_st.fs }}px;--fsm:{{ block_st.fsm }}px;--lh:{{ block_st.lh }};" {{ block.shopify_attributes }}>{{ block_st.title }}</div>
                            {% elsif block.type == 'custom_accent_text' %}
                                {% render 'sls-custom-accent-text', block: block %}
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
    </div>
{%- endcapture -%}
{{ top_banner | strip_newlines | remove: "  " | remove: "	" }}
