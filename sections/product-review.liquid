{%- capture quotes -%}
{%- liquid
    assign section_st = section.settings
-%}

<style>
  /* Profile Pic Styling */
  .custom_avatar img {
    width: 50px !important;  /* Small & dainty size */
    height: 50px !important;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto 10px auto;
    display: block;
    border: 1px solid #eee9e4;
  }

  /* Centering everything */
  .product_review .authour_text {
    text-align: center;
    width: 100%;
  }

  .product_review .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 10px;
  }

  .ratings {
    justify-content: center;
    display: flex;
    margin-bottom: 15px;
    gap: 2px;
  }

  .ratings svg {
    width: var(--icns);
    height: var(--icns);
    fill: var(--rating);
  }

  .author_name {
    margin-bottom: 5px;
    display: block;
  }

  .product_review--aligned .inner {
    justify-content: flex-start;
    gap: 6px;
  }

  .product_review--aligned .ratings {
    align-items: center;
    min-height: var(--icns);
    margin-bottom: 0;
  }

  .product_review--aligned .author_name {
    margin: 0;
  }

  .product_review--aligned .author_name p,
  .product_review--aligned .review_message p {
    margin: 0;
  }

  .product_review--aligned .review_message {
    margin-top: 16px;
    margin-bottom: 0;
  }

  @media only screen and (max-width: 767px) {
    .product_review--aligned .inner,
    .product_review--aligned .review_message {
      text-align: center;
    }
  }
</style>

<div class="sec_cov{% if section_st.hidem %} hide-sm{% endif %}{% if section_st.hided %} hide-md hide-lg{% endif %}{% if section_st.bgimg != blank %} bgImg lazyload zi1{% endif %}" style="--sbg:{% if section_st.bgg != blank %}{{ section_st.bgg }}{% else %}{{ section_st.bg }}{% endif %};--sst:{{ section_st.sst }}px;--ssb:{{ section_st.ssb }}px;--sstm:{{ section_st.sstm }}px;--ssbm:{{ section_st.ssbm }}px;--overlay:{{ section_st.overlay | color_modify: 'alpha', section_st.overlay_op }};"
     {% if section_st.bgimg != blank %}data-bgset="{{ section_st.bgimg | image_url: width: section_st.bgimg.width | image_tag: widths: '400,600,800,1000,1400,1600,2000,2400,3000' | split: 'srcset="' | last | split: '"' | first }}" data-sizes="auto" data-parent-fit="contain"{% endif %}>

    {%- capture style -%}--grsp:{{ section_st.gspace | divided_by: 2.0 }}px;--twidth:{{ section_st.twidth }}%;--icon_cl:{{ section_st.icon_cl }};--icns:{{ section_st.icon_size }}px; --bg:{{ section_st.bbg }};--rounded:{{ section_st.br }}px;--bpd:{{ section_st.bpd }}px;--eye:{{ section_st.eye_cl }};--eye_bg:{{ section_st.eye_bg }} {% endcapture %}

    <div class="{% if section_st.sw %}fw-sec{% else %}page-width{% endif %}" data-section-id="{{ section.id }}" data-section-style="quote{{ section_st.style }}">

        <div class="product_review product_review--aligned quote{{ section_st.style }}">

            {% if section.blocks.size > 0 %}
                {% render 'sec-title' %}

                {% capture testimonialdata %}
                  {% for block in section.blocks %}
                       {% assign block_st = block.settings %}
                        {% assign sindex = forloop.index0 %}

                        <div class="swiper-slide gitem fckSl{% if block_st.image != blank %} apic{% endif %} {{ section_st.style-m }} {{ section_st.style-t }} {{ section_st.style}}" id="{{ block.id }}" data-slide="{{ sindex }}" {{ block.shopify_attributes }}>
                            <div class="fl f-col m_auto w_100 h_100 gap" style="--cl:{{ section_st.cl }};--gap:{{ section_st.gspace }}px;">

                                <div class="authour_text fl fl1 f-col {% render 'animate-data', css:true %}" {% render 'animate-data' %} style="--rating:{{ section_st.icon_cl }};">
                                    <div class="fl f-jcc f-col inner m_auto h_100">

                                        {% comment %} 1. Author name {% endcomment %}
                                        {% if block_st.author != blank %}
                                          <div class="author_name rgTxt" style="--fs:{{ section_st.tfs | minus:1 }}px;--fsm:{{ section_st.tfsm }}px;--lh:{{ section_st.tlh }}; font-weight: 600;">
                                            {{ block_st.author }}
                                          </div>
                                        {% endif %}

                                        {% comment %} 2. Rating stars {% endcomment %}
                                        {% if block_st.rat %}
                                          <span class="ratings db">
                                            {% if block_st.rating == 1 %}{% render 'icon-star1' %}{% render 'icon-star' %}{% render 'icon-star' %}{% render 'icon-star' %}{% render 'icon-star' %}{% endif %}
                                            {% if block_st.rating == 2 %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% render 'icon-star' %}{% render 'icon-star' %}{% render 'icon-star' %}{% endif %}
                                            {% if block_st.rating == 3 %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% render 'icon-star' %}{% render 'icon-star' %}{% endif %}
                                            {% if block_st.rating == 4 %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% render 'icon-star' %}{% endif %}
                                            {% if block_st.rating == 5 %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% render 'icon-star1' %}{% endif %}
                                          </span>
                                        {% endif %}

                                        {% comment %} 3. Profile picture, if used {% endcomment %}
                                        {% if block_st.image != blank %}
                                        <div class="custom_avatar">
                                           {{ block_st.image | image_url: width: 150 | image_tag: loading: 'lazy', class: 'imgAt m_auto', alt: block_st.author }}
                                        </div>
                                        {% endif %}

                                        {% comment %} 4. Review Title & Content (Comment) {% endcomment %}
                                        {% if block_st.title != blank %}
                                          <div class="mb10 rgTxt {{ section_st.tff }}" style="--fs:{{ section_st.fs }}px;--fsm:{{ section_st.fsm }}px;--fw:{{ section_st.fw }};--lh:{{ section_st.lh }}; text-transform: uppercase; letter-spacing: 1px;">
                                            {{ block_st.title }}
                                          </div>
                                        {% endif %}

                                        {% if block_st.text != blank %}
                                          <div class="review_message rte-setting mb20 rgTxt" style="--fs:{{ section_st.tfs }}px;--fsm:{{ section_st.tfsm }}px;--lh:{{ section_st.tlh }};">
                                            {{ block_st.text }}
                                          </div>
                                        {% endif %}

                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% endcapture %}

                <slide-section class="grid gspace swiper" style="{{ style }}" data-swiper='{ "slidesPerView":"auto", "loop":{{ section_st.loop }}, {% if section_st.autoplay %}"autoplay":{ "delay":"{{ section_st.speed | times: 1000 }}" },{% endif %} "navigation":{ "nextEl":".swn{{ section.id }}","prevEl":".swp{{ section.id }}" },"pagination":{ "el":".swpg{{ section.id }}","clickable":true }}'>
                    <div class="swiper-wrapper">{{ testimonialdata }}</div>
                    {% render 'swiper-navigation', id:section.id, section_st:section_st %}
                </slide-section>
            {% endif %}
            {% if section.blocks.size == 0 %}{% render 'no-blocks' %}{% endif %}
        </div>
    </div>
</div>
{%- endcapture -%}
{{ quotes | strip_newlines | remove: "  " | remove: "   " }}
{% schema %}
